(function(){
  function todayEnd(){ const d=new Date(); d.setHours(23,59,59,999); return d; }
  function isToDate(r){ return !r.fechaCad || r.fechaCad <= todayEnd(); }
  function isCurrentMonth(r){ const n=new Date(); return r.fechaCad && r.fechaCad.getFullYear()===n.getFullYear() && r.fechaCad.getMonth()===n.getMonth(); }
  function daysInMonth(d){ return new Date(d.getFullYear(), d.getMonth()+1, 0).getDate(); }
  function monthName(ymVal){
    if(!ymVal || !/^\d{4}-\d{2}$/.test(ymVal)) return ymVal||'';
    const [y,m]=ymVal.split('-').map(Number);
    return new Date(y,m-1,1).toLocaleDateString('es-CL',{month:'short',year:'numeric'}).replace('.', '');
  }
  window.v38FilterMonth = function(m){
    S.filters.detalle = S.filters.detalle || {}; S.filters.detalle.mes = m;
    S.filters.perdidas = S.filters.perdidas || {}; S.filters.perdidas.mes = m;
    S.filters.proveedores = S.filters.proveedores || {}; S.filters.proveedores.mes = m;
    S.filters.motivos = S.filters.motivos || {}; S.filters.motivos.mes = m;
    S.active='detalle'; renderAll();
    setTimeout(()=>document.getElementById('sec-detalle')?.scrollIntoView({behavior:'smooth',block:'start'}),80);
  };
  window.v38FilterMotivo = function(mot){
    S.filters.detalle = S.filters.detalle || {}; S.filters.detalle.motivo = mot;
    S.filters.motivos = S.filters.motivos || {}; S.filters.motivos.motivo = mot;
    S.active='detalle'; renderAll();
    setTimeout(()=>document.getElementById('sec-detalle')?.scrollIntoView({behavior:'smooth',block:'start'}),80);
  };
  window.v38ClearMainFilters = function(){
    ['detalle','perdidas','proveedores','motivos'].forEach(sc=>{S.filters[sc]=S.filters[sc]||{}; delete S.filters[sc].mes; delete S.filters[sc].motivo;});
    S.active='resumen'; renderAll();
  };
  function progressPanel(rows){
    const now=new Date();
    const past=rows.filter(isToDate);
    const cur=rows.filter(r=>isCurrentMonth(r) && isToDate(r));
    const curAll=rows.filter(isCurrentMonth);
    const elapsed=now.getDate(), totalDays=daysInMonth(now), progress=Math.round(elapsed/totalDays*100);
    const curVal=sum(cur), curKg=sum(cur,'stock'), curLots=cur.length;
    const projected=elapsed>0?curVal/elapsed*totalDays:curVal;
    const months=[...new Set(past.map(r=>r.mes).filter(Boolean))].sort().slice(-6).reverse();
    const badges=months.map(m=>`<button type="button" class="v38-month-badge" onclick="v38FilterMonth('${esc(m)}')">📅 ${esc(monthName(m))}</button>`).join('') || '<span class="small">Sin meses cerrados hasta hoy.</span>';
    return `<div class="v38-progress"><div class="v38-progress-card"><h3>📍 Avance del mes hasta hoy</h3><div class="v38-hint">Se muestran solo vencimientos con fecha hasta hoy. Las fechas futuras quedan fuera del resumen principal.</div><div class="v38-bar"><div class="v38-fill" style="width:${progress}%"></div></div><div class="v38-hint">Día ${elapsed} de ${totalDays} · ${progress}% del mes transcurrido</div><div class="v38-progress-main"><div class="v38-mini-kpi"><b>${fmtCLP(curVal)}</b><span>Costo acumulado mes</span></div><div class="v38-mini-kpi"><b>${fmtNum(curKg)} KG</b><span>Kg acumulados</span></div><div class="v38-mini-kpi"><b>${fmtNum(curLots,0)}</b><span>Lotes hasta hoy</span></div></div><div class="v38-hint">Proyección referencial fin de mes: <b>${fmtCLP(projected)}</b>. Total calendario del mes cargado: ${fmtNum(curAll.length,0)} lotes.</div></div><div class="v38-progress-card"><h3>🖱️ Filtro rápido por mes</h3><div class="v38-hint">Presiona un mes para abrir el detalle filtrado. El gráfico también es clickeable.</div><div style="margin-top:8px">${badges}</div><button type="button" class="btn gray" style="margin-top:10px;padding:7px 10px;font-size:11px" onclick="v38ClearMainFilters()">Limpiar filtros rápidos</button></div></div>`;
  }
  function monthlyChartInteractive(rows){
    rows=rows.filter(isToDate);
    let by=Object.entries(group(rows,'mes')).map(([m,rs])=>({mes:m,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length})).sort((a,b)=>a.mes.localeCompare(b.mes));
    if(!by.length)return '<div class="empty">Sin vencimientos hasta hoy.</div>';
    let peak=by.reduce((a,b)=>b.valor>a.valor?b:a,by[0]);
    let last=by[by.length-1];
    let improvement=(peak.valor>0 && last.valor<=peak.valor)?Math.round((1-last.valor/peak.valor)*100):0;
    let data=by.length>12?by.slice(-12):by;
    let W=920,H=350,pL=64,pR=48,pT=40,pB=58,innerW=W-pL-pR,innerH=H-pT-pB;
    let maxVal=Math.max(1,...data.map(d=>d.valor));
    let step=innerW/data.length, bw=Math.max(20,Math.min(48,step*.58));
    let x=i=>pL+i*step+step/2, y=v=>pT+innerH-(v/maxVal)*innerH;
    let grid=[0,.25,.5,.75,1].map(t=>`<line x1="${pL}" y1="${pT+innerH*(1-t)}" x2="${W-pR}" y2="${pT+innerH*(1-t)}" stroke="#e2e8f0"/>`).join('');
    let bars=data.map((d,i)=>{let h=(d.valor/maxVal)*innerH, xx=x(i)-bw/2, yy=pT+innerH-h;let fill=d.mes===peak.mes?'#dc2626':(d.mes===last.mes?'#00843d':'#16a34a');return `<g class="v38-clickable" onclick="v38FilterMonth('${esc(d.mes)}')"><rect x="${xx.toFixed(1)}" y="${yy.toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.max(4,h).toFixed(1)}" rx="8" fill="${fill}" opacity=".82"><title>${esc(d.mes)} · ${fmtCLP(d.valor)} · ${fmtNum(d.kg)} KG · Click para filtrar</title></rect><text x="${x(i).toFixed(1)}" y="${Math.max(18,yy-7).toFixed(1)}" text-anchor="middle" font-size="10" fill="#0f172a" font-weight="900">${d.valor?('$'+Math.round(d.valor/1000000).toLocaleString('es-CL')+'M'):'$0'}</text></g>`;}).join('');
    let labels=data.map((d,i)=>`<g class="v38-clickable" onclick="v38FilterMonth('${esc(d.mes)}')"><text x="${x(i).toFixed(1)}" y="${H-28}" text-anchor="middle" font-size="11" fill="#334155" font-weight="900">${esc(d.mes.slice(5))}</text><text x="${x(i).toFixed(1)}" y="${H-13}" text-anchor="middle" font-size="10" fill="#64748b">${esc(d.mes.slice(0,4))}</text></g>`).join('');
    let status=improvement>0?`Mejora de ${improvement}% desde el pico visible`:'Tendencia en revisión';
    return `<div class="v38-chart-toolbar"><b>📊 ${status}</b><span>Solo hasta hoy · Click en barras/meses para filtrar detalle</span></div><svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;display:block">${grid}<line x1="${pL}" y1="${pT+innerH}" x2="${W-pR}" y2="${pT+innerH}" stroke="#cbd5e1"/><line x1="${pL}" y1="${pT}" x2="${pL}" y2="${pT+innerH}" stroke="#cbd5e1"/>${bars}${labels}<text x="${pL}" y="20" font-size="13" fill="#334155" font-weight="950">Valor perdido por mes de vencimiento</text><text x="${W-pR}" y="20" text-anchor="end" font-size="11" fill="#64748b">Futuro excluido</text></svg>`;
  }
  function motivosInteractive(rows){
    rows=rows.filter(isToDate);
    let data=Object.entries(group(rows,'motivo')).map(([m,rs])=>({m,rs,valor:sum(rs),kg:sum(rs,'stock')})).sort((a,b)=>b.valor-a.valor);
    if(!data.length)return '<div class="empty">Sin motivos hasta hoy.</div>';
    let mx=Math.max(1,...data.map(d=>d.valor));
    return `<div class="v38-chart-toolbar"><b>🎯 Motivos hasta hoy</b><span>Click en un motivo para abrir detalle filtrado</span></div><div class="motivo-bars">${data.map((d,i)=>{let w=Math.max(2,Math.round(d.valor/mx*100));let color=['#00843d','#2563eb','#df5a00','#7c3aed','#dc2626','#0f766e'][i%6];return `<div class="motivo-row v38-clickable" onclick="v38FilterMotivo('${esc(d.m)}')"><div class="motivo-name">${badge(d.m)}</div><div class="motivo-track"><div class="motivo-fill" style="width:${w}%;background:${color}"></div></div><div class="motivo-val"><b>${fmtCLP(d.valor)}</b><small>${fmtNum(d.kg)} KG · ${fmtNum(d.rs.length,0)} lotes</small></div></div>`}).join('')}</div>`;
  }
  const oldResumen=window.renderResumen;
  window.renderResumen=function(){
    let loss=S.loss||[], stockValid=(S.stock||[]).filter(r=>!r.obsoleto&&num(r.dias)>=0);
    let pastLoss=loss.filter(isToDate);
    let venc=pastLoss.filter(r=>r.motivo==='Vencido');
    let futureLoss=loss.filter(r=>!isToDate(r));
    return `<section class="section active" id="sec-resumen">${executiveAlerts(loss,stockValid)}${progressPanel(loss)}<div class="v38-total-note"><b>Resumen total histórico/calendario completo</b><span>Estos totales mantienen toda la información cargada, incluyendo fechas futuras. Solo el avance, filtros rápidos y gráficos excluyen futuro.</span></div>${kpiHTML(loss)}${kpiLifeHTML(loss)}<div class="grid2"><div class="card"><div class="section-title">Pérdida por mes de vencimiento · hasta hoy</div><div class="card-pad">${monthlyChartInteractive(loss)}</div></div><div class="card"><div class="section-title">Pérdida por motivo · hasta hoy</div><div class="card-pad">${motivosInteractive(loss)}</div></div></div><div class="grid3"><div class="card"><div class="section-title">Vencidos hasta hoy</div><div class="card-pad"><b>${fmtCLP(sum(venc))}</b><br><span class="small">${fmtNum(venc.length,0)} lotes · ${fmtNum(sum(venc,'stock'))} KG</span></div></div><div class="card"><div class="section-title">Fechas futuras conservadas</div><div class="card-pad"><b>${fmtCLP(sum(futureLoss))}</b><br><span class="small">${fmtNum(futureLoss.length,0)} lotes · no se muestran en gráficos de avance.</span></div></div><div class="card"><div class="section-title">Sin precio hasta hoy</div><div class="card-pad"><b>${fmtNum(pastLoss.filter(r=>!r.precio).length,0)}</b><br><span class="small">Registros con motivo sin cruce de precio.</span></div></div></div></section>`;
  };
  const oldRenderAllV38=window.renderAll;
  if(typeof oldRenderAllV38==='function'){
    window.renderAll=function(){ return oldRenderAllV38.apply(this,arguments); };
  }
})();

;

(function(){
  function v40TodayEnd(){const d=new Date();d.setHours(23,59,59,999);return d;}
  function v40IsToDate(r){return !r.fechaCad || r.fechaCad<=v40TodayEnd();}
  function v40MonthName(m){try{if(!m||!/^[0-9]{4}-[0-9]{2}$/.test(m))return m||'';const p=m.split('-').map(Number);return new Date(p[0],p[1]-1,1).toLocaleDateString('es-CL',{month:'short',year:'numeric'}).replace('.','');}catch(e){return m||''}}
  function v40PositiveInsights(rows){
    rows=(rows||[]).filter(v40IsToDate).filter(r=>r && r.mes);
    if(!rows.length)return '';
    const by=Object.entries(group(rows,'mes')).map(([m,rs])=>({m,rs,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length})).sort((a,b)=>a.m.localeCompare(b.m));
    const last=by[by.length-1]||{valor:0,kg:0,lotes:0,m:''};
    const prev=by[by.length-2]||null;
    const peak=by.reduce((a,b)=>b.valor>a.valor?b:a,by[0]||last);
    const improvement=(peak&&peak.valor>0)?Math.max(0,Math.round((1-last.valor/peak.valor)*100)):0;
    const prevDelta=(prev&&prev.valor>0)?Math.round((1-last.valor/prev.valor)*100):null;
    const commented=(S.loss||[]).filter(r=>{try{return !!getGestionComment(r)}catch(e){return false}}).length;
    const total=(S.loss||[]).length||1;
    const commentPct=Math.round(commented/total*100);
    let cards=[];
    cards.push(`<div class="v40-positive-card"><b>✅ Lectura gerencial más clara</b><span>El total histórico se mantiene completo, pero los gráficos muestran solo el avance <strong>hasta hoy</strong>. Así no se mezclan vencimientos futuros con gestión actual.</span></div>`);
    if(improvement>0){
      cards.push(`<div class="v40-positive-card"><b>📉 Tendencia favorable visible</b><span>El último mes visible está <strong>${improvement}%</strong> bajo el peak del período cargado. Es una buena señal para explicar mejora y foco de control.</span></div>`);
    }else{
      cards.push(`<div class="v40-positive-card warn"><b>📊 Tendencia en seguimiento</b><span>El dashboard ya separa avance real de fechas futuras, permitiendo revisar el mes actual sin distorsión y priorizar acciones.</span></div>`);
    }
    if(prevDelta!==null && prevDelta>0){
      cards.push(`<div class="v40-positive-card"><b>🟢 Mejora vs mes anterior</b><span>${v40MonthName(last.m)} está <strong>${prevDelta}%</strong> bajo ${v40MonthName(prev.m)} a nivel de valor acumulado visible.</span></div>`);
    }else if(commented>0){
      cards.push(`<div class="v40-positive-card info"><b>💬 Gestión documentada</b><span>Ya existen <strong>${commented}</strong> registros con comentario de gestión (${commentPct}% del total cargado), dejando trazabilidad para revisión de gerencia.</span></div>`);
    }else{
      cards.push(`<div class="v40-positive-card info"><b>☁️ Base colaborativa activa</b><span>Comentarios guardados en Firebase y archivos centralizados en GitHub/Vercel. Todos ven la misma información.</span></div>`);
    }
    return `<div class="v40-positive-panel">${cards.join('')}</div>`;
  }
  const oldResumenV40=window.renderResumen;
  if(typeof oldResumenV40==='function' && !oldResumenV40.__v40Positive){
    window.renderResumen=function(){
      let html=oldResumenV40.apply(this,arguments);
      const panel=v40PositiveInsights(S.loss||[]);
      if(panel && html.includes('<div class="v38-total-note"')) html=html.replace('<div class="v38-total-note"',panel+'<div class="v38-total-note"');
      else if(panel && html.includes('</section>')) html=html.replace('</section>',panel+'</section>');
      return html;
    };
    window.renderResumen.__v40Positive=true;
  }
  function compactAdminCarga(){
    const sec=document.getElementById('carga');
    if(!sec || sec.classList.contains('v40-carga-compact'))return;
    const pad=sec.querySelector('.card-pad');
    if(!pad)return;
    sec.classList.add('v40-carga-compact');
    const shell=document.createElement('details');
    shell.className='v40-admin-shell';
    const summary=document.createElement('summary');
    summary.innerHTML='<span>☁️ Base automática activa · Administración de carga</span><span class="v40-status-pill">GitHub/Vercel + Firebase</span>';
    const body=document.createElement('div');
    body.className='v40-admin-body';
    while(pad.firstChild) body.appendChild(pad.firstChild);
    shell.appendChild(summary); shell.appendChild(body); pad.appendChild(shell);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',compactAdminCarga); else compactAdminCarga();
  const oldRenderAllV40=window.renderAll;
  if(typeof oldRenderAllV40==='function' && !oldRenderAllV40.__v40Compact){
    window.renderAll=function(){const r=oldRenderAllV40.apply(this,arguments);setTimeout(compactAdminCarga,0);return r;};
    window.renderAll.__v40Compact=true;
  }
})();

;

import { initializeApp, getApps, getApp } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-app.js";
import { getFirestore, collection, getDocs, doc, setDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-firestore.js";
const firebaseConfig = {apiKey:"AIzaSyCxifqfJD89epa8MVLjDesydh5pLiIoNTU",authDomain:"dashboard-calidad-y-costos.firebaseapp.com",projectId:"dashboard-calidad-y-costos",storageBucket:"dashboard-calidad-y-costos.firebasestorage.app",messagingSenderId:"256388106071",appId:"1:256388106071:web:f8e6a05da4926d5015e012",measurementId:"G-8KVX39G2LG"};
const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
const db = getFirestore(app);
const COLL = 'evaluaciones_materiales';
const LOCAL = 'mvEvaluacionMaterialesV1';
let remoteEvals = {};
function safeId(key){try{return btoa(unescape(encodeURIComponent(String(key||'')))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/g,'')}catch(e){return String(key||'').replace(/[^\w.-]/g,'_').slice(0,120)}}
function readLocal(){try{return JSON.parse(localStorage.getItem(LOCAL)||'{}')}catch(e){return {}}}
function writeLocal(m){try{localStorage.setItem(LOCAL,JSON.stringify(m||{}))}catch(e){}}
window.loadMaterialEvals = function(){return Object.assign({}, readLocal(), remoteEvals)};
window.saveMaterialEval = async function(key, patch){
  const cur = window.loadMaterialEvals();
  const clean = Object.assign({}, cur[key]||{}, patch||{});
  clean.actualizadoLocal = new Date().toISOString();
  cur[key]=clean; remoteEvals[key]=clean; writeLocal(cur);
  try{await setDoc(doc(db,COLL,safeId(key)), Object.assign({key,actualizadoEn:serverTimestamp(),version:'v41-evaluacion-materiales'}, clean), {merge:true}); return true;}catch(err){console.error('No se pudo guardar evaluación en Firebase:',err); return false;}
};
async function loadRemote(){try{const snap=await getDocs(collection(db,COLL));const m={};snap.forEach(d=>{const data=d.data()||{};if(data.key)m[data.key]=data});remoteEvals=m;writeLocal(Object.assign({}, readLocal(), remoteEvals)); if(window.S&&S.active==='evaluacion'&&typeof renderAll==='function') setTimeout(renderAll,150);}catch(e){console.warn('Evaluaciones solo local:',e)}}
document.addEventListener('click',async e=>{
  if(e.target&&e.target.id==='evalExportBtn'){
    const rows=[...document.querySelectorAll('tr[data-eval-row]')];
    const csv=['Material;Descripcion;Proveedor;Categoria;Codigo FT;Trimestre;Funcional;Calidad/Inocuidad;Cumplimiento tecnico;Fecha revision;Comentario'];
    rows.forEach(tr=>{const t=[...tr.children].map(td=>td.innerText.trim().replace(/\s+/g,' '));const vals=[t[0],t[1],t[2],t[3],tr.querySelector('[data-field="ft"]')?.value||'',tr.querySelector('[data-field="trimestre"]')?.value||'',tr.querySelector('[data-field="funcional"]')?.value||'',tr.querySelector('[data-field="calidad"]')?.value||'',tr.querySelector('[data-field="tecnico"]')?.value||'',tr.querySelector('[data-field="fechaRev"]')?.value||'',tr.querySelector('[data-field="comentario"]')?.value||''];csv.push(vals.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(';'))});
    const blob=new Blob([csv.join('\n')],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='evaluacion_materiales_proveedores.csv';a.click();URL.revokeObjectURL(a.href);return;
  }
  if(!e.target||!e.target.classList||!e.target.classList.contains('eval-save')) return;
  const key=e.target.dataset.evalK;const tr=e.target.closest('tr');if(!key||!tr)return;
  const patch={};tr.querySelectorAll('.eval-input').forEach(inp=>{patch[inp.dataset.field]=inp.value});
  const st=tr.querySelector(`[data-eval-status="${CSS.escape(key)}"]`);if(st){st.textContent='Guardando...';st.classList.remove('ok')}
  const ok=await window.saveMaterialEval(key,patch);if(st){st.textContent=ok?'☁️ Guardado Firebase':'💾 Guardado local';st.classList.add('ok')}
},true);
loadRemote();

;

(function(){
  const HIST_LOCAL='mvEvaluacionMaterialesHistorialV1';
  function readHistLocal(){try{return JSON.parse(localStorage.getItem(HIST_LOCAL)||'[]')}catch(e){return []}}
  function writeHistLocal(arr){try{localStorage.setItem(HIST_LOCAL,JSON.stringify(arr||[]))}catch(e){}}
  window.loadMaterialEvalHistory = window.loadMaterialEvalHistory || function(){return readHistLocal()};
  window.__writeMaterialEvalHistoryLocal = writeHistLocal;

  window.renderEvaluacion = function(){
    let all=buildSkuMaster();
    let evals=(window.loadMaterialEvals?window.loadMaterialEvals():loadSkuEvals());
    let hist=(window.loadMaterialEvalHistory?window.loadMaterialEvalHistory():readHistLocal())||[];
    let f=S.filters.evaluacion||{};
    let rows=all.map(item=>{let ev=evals[evalKey(item)]||{};let scores=['funcional','calidad','tecnico'].map(k=>Number(ev[k])||0).filter(x=>x>0);let avg=scores.length?scores.reduce((a,b)=>a+b,0)/scores.length:0;let st=ev.estado||evalStatus(avg);return {...item,ev,avg,estado:st,ft:ev.ft||'',fechaRev:ev.fechaRev||'',trimestre:ev.trimestre||evalQuarter(),comentario:ev.comentario||''}});
    rows=rows.filter(r=>!f.search||[r.mat,r.desc,r.proveedor,r.ft,r.comentario,r.categoria].join(' ').toLowerCase().includes(String(f.search).toLowerCase()));
    rows=rows.filter(r=>!f.prov||f.prov==='Todos'||r.proveedor===f.prov).filter(r=>!f.cat||f.cat==='Todos'||r.categoria===f.cat).filter(r=>!f.estado||f.estado==='Todos'||r.estado===f.estado).filter(r=>!f.ft||f.ft==='Todos'||(f.ft==='Con FT'?!!r.ft:!r.ft));
    let sinft=rows.filter(r=>!r.ft).length,crit=rows.filter(r=>r.estado==='Crítico').length,completos=rows.filter(r=>r.ft&&r.avg&&r.fechaRev).length;
    let histSorted=[...hist].sort((a,b)=>String(b.fechaCierre||'').localeCompare(String(a.fechaCierre||''))).slice(0,300);
    let histCrit=histSorted.filter(r=>r.estado==='Crítico').length;
    const statusOptions=(sel)=>['Pendiente','Aprobado','Observado','Crítico'].map(x=>`<option ${sel===x?'selected':''}>${x}</option>`).join('');
    const histRows = histSorted.length ? histSorted.map(h=>`<tr data-hist-id="${esc(h.histId||'')}"><td class="nowrap">${esc((h.fechaCierre||'').slice(0,10)||'—')}</td><td class="c"><b>${esc(h.mat||'')}</b></td><td class="desc">${esc(h.desc||'')}</td><td class="prov">${esc(h.proveedor||'')}</td><td>${esc(h.ft||'')}</td><td>${esc(h.trimestre||'')}</td><td class="c">${esc(h.funcional||'—')}</td><td class="c">${esc(h.calidad||'—')}</td><td class="c">${esc(h.tecnico||'—')}</td><td class="c"><b>${h.promedio?fmtNum(h.promedio,1):'—'}</b></td><td class="c"><span class="eval-status ${evalStatusClass(h.estado||'Pendiente')}">${esc(h.estado||'Pendiente')}</span></td><td>${esc(h.comentario||'')}</td><td class="c"><button class="eval-hist-delete" data-hist-id="${esc(h.histId||'')}">Eliminar</button></td></tr>`).join('') : `<tr><td colspan="13" class="eval-hist-empty">Aún no hay evaluaciones cerradas. Usa “Cerrar evaluación” para enviar una copia permanente al historial.</td></tr>`;
    return `<section class="section" id="sec-evaluacion"><div class="eval-intro"><div class="eval-info"><b>🧪 Evaluación trimestral de materiales y proveedores</b><span>Ahora el módulo separa evaluaciones en proceso e historial cerrado. Guardar mantiene el registro editable; Cerrar evaluación crea una copia permanente para revisión trimestral.</span></div><div class="eval-kpis"><div class="eval-kpi"><b>${fmtNum(rows.length,0)}</b><span>SKU / proveedor visibles</span></div><div class="eval-kpi warn"><b>${fmtNum(sinft,0)}</b><span>Sin código FT</span></div><div class="eval-kpi danger"><b>${fmtNum(crit,0)}</b><span>Críticos en proceso</span></div></div></div><div class="card"><div class="section-title">Evaluación en proceso · editable</div><div class="eval-tabs"><span class="eval-tab-pill green">💾 Guardar = mantiene editable</span><span class="eval-tab-pill blue">📚 Cerrar = copia al historial</span><span class="eval-tab-pill orange">🧾 Historial: ${fmtNum(histSorted.length,0)} cerradas · ${fmtNum(histCrit,0)} críticas</span></div><div class="eval-filters"><div class="field"><label>Buscar</label><input data-s="evaluacion" data-f="search" value="${esc(f.search||'')}" placeholder="SKU, proveedor, FT, comentario..."></div><div class="field"><label>Proveedor</label><select data-s="evaluacion" data-f="prov"><option>Todos</option>${options(all.map(r=>r.proveedor),f.prov)}</select></div><div class="field"><label>Categoría</label><select data-s="evaluacion" data-f="cat"><option>Todos</option>${options(all.map(r=>r.categoria),f.cat)}</select></div><div class="field"><label>Estado</label><select data-s="evaluacion" data-f="estado"><option>Todos</option>${options(['Aprobado','Observado','Crítico','Pendiente'],f.estado)}</select></div><div class="field"><label>FT</label><select data-s="evaluacion" data-f="ft"><option>Todos</option><option ${f.ft==='Con FT'?'selected':''}>Con FT</option><option ${f.ft==='Sin FT'?'selected':''}>Sin FT</option></select></div></div><div class="table-wrap"><table class="eval-table"><thead><tr><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Categoría</th><th>Código FT</th><th>Trimestre</th><th>Funcional<br>proceso/producto</th><th>Calidad e<br>inocuidad</th><th>Cumplimiento<br>técnico</th><th>Promedio</th><th>Estado</th><th>Última<br>revisión</th><th>Comentario / acción</th><th>Acciones</th></tr></thead><tbody>${rows.map(r=>{let k=evalKey(r),ev=r.ev||{};return `<tr data-eval-row="${esc(k)}"><td class="c"><b>${esc(r.mat)}</b></td><td class="desc">${esc(r.desc)}</td><td class="prov">${esc(r.proveedor)}</td><td>${esc(r.categoria)}</td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="ft" value="${esc(r.ft)}" placeholder="FT-000"></td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="trimestre" value="${esc(r.trimestre)}"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="funcional" type="number" min="1" max="5" value="${esc(ev.funcional||'')}" placeholder="1-5"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="calidad" type="number" min="1" max="5" value="${esc(ev.calidad||'')}" placeholder="1-5"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="tecnico" type="number" min="1" max="5" value="${esc(ev.tecnico||'')}" placeholder="1-5"></td><td class="c"><b>${r.avg?fmtNum(r.avg,1):'—'}</b></td><td class="c"><select class="eval-status-select eval-input" data-eval-k="${esc(k)}" data-field="estado">${statusOptions(r.estado)}</select></td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="fechaRev" type="date" value="${esc(r.fechaRev)}"></td><td><input class="eval-comment eval-input" data-eval-k="${esc(k)}" data-field="comentario" value="${esc(r.comentario)}" placeholder="Reclamos, defectos, mejora, responsable..."></td><td class="c"><div class="eval-actions-stack"><button class="eval-save" data-eval-k="${esc(k)}">Guardar</button><button class="eval-close" data-eval-k="${esc(k)}">Cerrar evaluación</button><span class="eval-saved ${r.ft||r.avg?'ok':'warn'}" data-eval-status="${esc(k)}">${r.ft||r.avg?'En proceso guardado':'Pendiente completar'}</span></div></td></tr>`}).join('')}</tbody></table></div><div class="eval-export"><small>${fmtNum(completos,0)} evaluaciones completas de ${fmtNum(rows.length,0)} visibles · Escala 1 bajo / 5 excelente.</small><button class="eval-btn-gray" id="evalExportBtn">Exportar evaluación en proceso CSV</button></div></div><div class="card eval-history-card"><div class="section-title">Historial de evaluaciones cerradas · no editable</div><div class="eval-export"><small class="eval-history-note">Cada cierre guarda una foto del material/proveedor con fecha, notas y resultado. No se sobrescribe al seguir editando la evaluación en proceso. Si hubo un error, se puede eliminar usando clave autorizada.</small><div class="eval-history-toolbar"><span class="eval-history-keynote">🔐 Eliminar requiere clave</span><button class="eval-btn-gray" id="evalHistExportBtn">Exportar historial CSV</button></div></div><div class="table-wrap"><table class="eval-history-table"><thead><tr><th>Fecha cierre</th><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Código FT</th><th>Trimestre</th><th>Funcional</th><th>Calidad</th><th>Técnico</th><th>Prom.</th><th>Resultado</th><th>Comentario</th><th>Acción</th></tr></thead><tbody>${histRows}</tbody></table></div></div></section>`;
  };
})();

;

import { initializeApp, getApps, getApp } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-app.js";
import { getFirestore, collection, getDocs, doc, setDoc, deleteDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-firestore.js";
const firebaseConfig = {apiKey:"AIzaSyCxifqfJD89epa8MVLjDesydh5pLiIoNTU",authDomain:"dashboard-calidad-y-costos.firebaseapp.com",projectId:"dashboard-calidad-y-costos",storageBucket:"dashboard-calidad-y-costos.firebasestorage.app",messagingSenderId:"256388106071",appId:"1:256388106071:web:f8e6a05da4926d5015e012",measurementId:"G-8KVX39G2LG"};
const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
const db = getFirestore(app);
const HIST_COLL='evaluaciones_materiales_historial';
const HIST_LOCAL='mvEvaluacionMaterialesHistorialV1';
let remoteHist=[];
function safeId(key){try{return btoa(unescape(encodeURIComponent(String(key||'')))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/g,'')}catch(e){return String(key||'').replace(/[^\w.-]/g,'_').slice(0,120)}}
function readLocal(){try{return JSON.parse(localStorage.getItem(HIST_LOCAL)||'[]')}catch(e){return []}}
function writeLocal(arr){try{localStorage.setItem(HIST_LOCAL,JSON.stringify(arr||[]))}catch(e){}}
function mergedHist(){const m={};[...readLocal(),...remoteHist].forEach(r=>{if(r&&r.histId)m[r.histId]=r});return Object.values(m)}
window.loadMaterialEvalHistory=function(){return mergedHist()};
window.saveMaterialEvalHistory=async function(record){
  const histId = record.histId || (record.key+'|'+new Date().toISOString());
  const clean=Object.assign({},record,{histId,fechaCierre:record.fechaCierre||new Date().toISOString(),version:'v42-historial-evaluacion'});
  const local=mergedHist().filter(r=>r.histId!==histId);local.push(clean);remoteHist=local;writeLocal(local);
  try{await setDoc(doc(db,HIST_COLL,safeId(histId)), Object.assign({},clean,{actualizadoEn:serverTimestamp()}), {merge:false});return true}catch(e){console.error('No se pudo guardar historial evaluación:',e);return false}
};
const HIST_DELETE_KEY='CALIDAD2026';
window.deleteMaterialEvalHistory=async function(histId, clave){
  if(String(clave||'').trim()!==HIST_DELETE_KEY) throw new Error('Clave incorrecta');
  const local=mergedHist().filter(r=>r.histId!==histId);
  remoteHist=remoteHist.filter(r=>r.histId!==histId);
  writeLocal(local);
  try{await deleteDoc(doc(db,HIST_COLL,safeId(histId)));return true}catch(e){console.error('No se pudo eliminar historial en Firebase:',e);return false}
};
async function loadHistRemote(){try{const snap=await getDocs(collection(db,HIST_COLL));const arr=[];snap.forEach(d=>{arr.push(d.data()||{})});remoteHist=arr;writeLocal(mergedHist());if(window.S&&S.active==='evaluacion'&&typeof renderAll==='function')setTimeout(renderAll,150)}catch(e){console.warn('Historial evaluación solo local:',e)}}
document.addEventListener('click',async e=>{
  if(e.target&&e.target.classList&&e.target.classList.contains('eval-hist-delete')){
    const histId=e.target.dataset.histId;
    if(!histId)return;
    const clave=prompt('Ingresa clave para eliminar esta evaluación cerrada:');
    if(clave===null)return;
    if(!confirm('¿Confirmas eliminar esta evaluación cerrada del historial?'))return;
    e.target.textContent='Eliminando...';
    try{
      const ok=await window.deleteMaterialEvalHistory(histId,clave);
      alert(ok?'Evaluación eliminada del historial.':'Eliminada localmente, pero no se pudo confirmar en Firebase.');
      if(typeof renderAll==='function')setTimeout(renderAll,150);
    }catch(err){alert(err.message||'No se pudo eliminar.'); e.target.textContent='Eliminar';}
    return;
  }
  if(e.target&&e.target.id==='evalHistExportBtn'){
    const hist=(window.loadMaterialEvalHistory?window.loadMaterialEvalHistory():[]).sort((a,b)=>String(b.fechaCierre||'').localeCompare(String(a.fechaCierre||'')));
    const csv=['Fecha cierre;Material;Descripcion;Proveedor;Codigo FT;Trimestre;Funcional;Calidad/Inocuidad;Cumplimiento tecnico;Promedio;Estado;Comentario'];
    hist.forEach(h=>csv.push([h.fechaCierre,h.mat,h.desc,h.proveedor,h.ft,h.trimestre,h.funcional,h.calidad,h.tecnico,h.promedio,h.estado,h.comentario].map(v=>'"'+String(v||'').replace(/"/g,'""')+'"').join(';')));
    const blob=new Blob([csv.join('\n')],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='historial_evaluacion_materiales_proveedores.csv';a.click();URL.revokeObjectURL(a.href);return;
  }
  if(!e.target||!e.target.classList||!e.target.classList.contains('eval-close'))return;
  const key=e.target.dataset.evalK;const tr=e.target.closest('tr');if(!key||!tr)return;
  const patch={};tr.querySelectorAll('.eval-input').forEach(inp=>{patch[inp.dataset.field]=inp.value});
  const t=[...tr.children].map(td=>td.innerText.trim().replace(/\s+/g,' '));
  const scores=['funcional','calidad','tecnico'].map(k=>Number(patch[k])||0).filter(x=>x>0);
  const promedio=scores.length?scores.reduce((a,b)=>a+b,0)/scores.length:0;
  const rec={key,mat:t[0],desc:t[1],proveedor:t[2],categoria:t[3],ft:patch.ft||'',trimestre:patch.trimestre||'',funcional:patch.funcional||'',calidad:patch.calidad||'',tecnico:patch.tecnico||'',promedio,estado:patch.estado||'',fechaRev:patch.fechaRev||'',comentario:patch.comentario||'',fechaCierre:new Date().toISOString()};
  const st=tr.querySelector(`[data-eval-status="${CSS.escape(key)}"]`);if(st){st.textContent='Cerrando...';st.classList.remove('ok','warn')}
  if(window.saveMaterialEval) await window.saveMaterialEval(key,patch);
  const ok=await window.saveMaterialEvalHistory(rec);
  if(st){st.textContent=ok?'📚 Cerrada en historial':'💾 Cerrada local';st.classList.add('ok')}
  if(typeof renderAll==='function')setTimeout(renderAll,500);
},true);
loadHistRemote();

;

(function(){
  function pad(n){return String(n).padStart(2,'0')}
  function setUpdateV43(){
    var el=document.getElementById('lastUpdateV43');
    if(!el) return;
    var d=new Date();
    el.textContent=pad(d.getDate())+'-'+pad(d.getMonth()+1)+'-'+d.getFullYear()+' '+pad(d.getHours())+':'+pad(d.getMinutes());
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',setUpdateV43); else setUpdateV43();
})();

;

(function(){
  function ready(fn){ if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',fn); else fn(); }
  function safe(fn,fallback){try{return fn()}catch(e){console.warn('v60',e);return fallback}}
  function maxVal(arr,k){return Math.max(1,...arr.map(x=>Number(x[k]||0)))}
  function moneyShort(n){ n=Number(n||0); if(n>=1000000) return '$'+(n/1000000).toLocaleString('es-CL',{maximumFractionDigits:1})+'M'; return fmtCLP(n).replace('$ ','$'); }
  function colorFor(i){return ['#ef2029','#ff7a1a','#ffc928','#854be8','#2d74f0','#00a0a8','#94a3b8'][i%7]}
  function lineChartByMonth(rows){
    var g=group(rows,r=>r.mes||'Sin fecha'); var months=Object.keys(g).sort(); var data=months.map(m=>({m,v:sum(g[m])})).filter(x=>x.m&&x.m!=='Sin fecha').slice(-12);
    if(!data.length) return '<div class="empty">Sin datos</div>';
    var max=Math.max(1,...data.map(d=>d.v)), w=620,h=180,p=18;
    var pts=data.map((d,i)=>{var x=p+(i*(w-2*p)/Math.max(1,data.length-1)); var y=h-p-(d.v/max)*(h-2*p); return [x,y,d];});
    var poly=pts.map(p=>p[0]+','+p[1]).join(' ');
    var area='M'+pts[0][0]+','+(h-p)+' L'+pts.map(p=>p[0]+','+p[1]).join(' L')+' L'+pts[pts.length-1][0]+','+(h-p)+' Z';
    var labels=pts.map(p=>'<text x="'+p[0]+'" y="176" text-anchor="middle" font-size="11" fill="#334155">'+esc(String(p[2].m).slice(5))+'</text>').join('');
    var circles=pts.map(p=>'<circle cx="'+p[0]+'" cy="'+p[1]+'" r="4" fill="#fff" stroke="#ef2029" stroke-width="3"><title>'+esc(p[2].m+' · '+fmtCLP(p[2].v))+'</title></circle>').join('');
    return '<div class="v60-linechart"><svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="none"><path d="'+area+'" fill="rgba(239,32,41,.12)"/><polyline points="'+poly+'" fill="none" stroke="#ef2029" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>'+circles+labels+'</svg></div>';
  }
  function barsHTML(rows, groupFn, valueFn, limit){
    var g=group(rows,groupFn); var arr=Object.keys(g).map(k=>({name:k, value:valueFn?valueFn(g[k]):sum(g[k]), count:g[k].length, kg:sum(g[k],'stock')})).sort((a,b)=>b.value-a.value).slice(0,limit||5); var mx=maxVal(arr,'value');
    if(!arr.length) return '<div class="empty">Sin datos</div>';
    return arr.map((r,i)=>'<div class="v60-bar-row"><div>'+esc(r.name)+'</div><div class="v60-track"><div class="v60-fill" style="width:'+Math.max(4,(r.value/mx*100))+'%;background:'+colorFor(i)+'"></div></div><div class="v60-val">'+fmtCLP(r.value).replace('$ ','$')+'<br><span style="color:#64748b;font-size:11px">'+fmtNum(r.count,0)+' casos</span></div></div>').join('');
  }
  function causaCat(text){
    var s=lower(text||'');
    if(!s) return 'Sin comentario';
    if(s.includes('valle del norte')||s.includes('proveedor')||s.includes('devolu')||s.includes('extensi')||s.includes('recep')||s.includes('vida util')||s.includes('vida útil')) return 'Proveedor';
    if(s.includes('politica')||s.includes('política')||s.includes('sobrestock')||s.includes('compra')||s.includes('proye')||s.includes('planific')) return 'Planificación';
    if(s.includes('formula')||s.includes('fórmula')||s.includes('receta')||s.includes('maestro')||s.includes('desarrollo')) return 'Desarrollo / Fórmulas';
    if(s.includes('fifo')||s.includes('operaci')||s.includes('producci')||s.includes('gestion interna')||s.includes('gestión interna')) return 'Operación (FIFO)';
    if(s.includes('venta')||s.includes('cliente')||s.includes('comercial')||s.includes('aceptaci')) return 'Comercial';
    if(s.includes('sap')||s.includes('sistema')||s.includes('fecha incorrecta')||s.includes('error sistema')) return 'Sistema SAP';
    if(s.includes('calidad')||s.includes('rechazo')||s.includes('sensorial')) return 'Calidad';
    return 'Otros';
  }
  function resp(c){return {'Proveedor':'Abastecimiento','Planificación':'Planificación','Desarrollo / Fórmulas':'Desarrollo','Operación (FIFO)':'Producción','Comercial':'Comercial','Sistema SAP':'Master Data','Calidad':'Calidad','Otros':'Planificación','Sin comentario':'Planificación'}[c]||'Planificación'}
  function causeRows(){return (S.loss||[]).map(r=>{var cg=getGestionComment(r)||r.comentario||r.motivo||''; var cat=causaCat(cg); return Object.assign({},r,{causa:cat,responsable:resp(cat),comentarioCausa:cg});});}
  function topComments(rows){var g={}; rows.forEach(r=>{var c=norm(getGestionComment(r)||r.comentario||r.motivo||'Sin comentario'); g[c]=(g[c]||0)+1}); return Object.keys(g).map(k=>({name:k,count:g[k]})).sort((a,b)=>b.count-a.count).slice(0,5)}
  window.renderCausasV60=function(){var rows=causeRows(); var total=rows.length, totalVal=sum(rows); var by=Object.entries(group(rows,'causa')).map(([k,v])=>({name:k,count:v.length,value:sum(v),resp:resp(k)})).sort((a,b)=>b.count-a.count); var main=by[0]||{name:'Sin datos',count:0,value:0,resp:'—'}; var impact=[...by].sort((a,b)=>b.value-a.value)[0]||main; var top5=by.slice(0,5).reduce((s,x)=>s+x.count,0); var maxC=maxVal(by,'count'); var maxV=maxVal(by,'value'); var comments=topComments(rows); var conic=by.slice(0,7).reduce((acc,x,i)=>{var pctv=totalVal?x.value/totalVal*100:0; var start=acc.sum; acc.parts.push(colorFor(i)+' '+start+'% '+(start+pctv)+'%'); acc.sum+=pctv; return acc},{sum:0,parts:[]}).parts.join(',');
    return '<section class="section active" id="sec-causas"><div class="v60-header"><div class="v60-title"><h1>Causas raíz</h1><span>Análisis gerencial de comentarios, responsables e impacto económico.</span></div></div><div class="v60-causas-grid"><div class="v60-card"><h3>Causas raíz principales ⓘ</h3><div class="v60-mini-kpis"><div class="v60-mini" style="background:#fff1f2"><span>Causa principal</span><b>'+esc(main.name)+'</b><small>'+fmtNum(main.count,0)+' casos</small></div><div class="v60-mini" style="background:#fff7ed"><span>Mayor impacto $</span><b>'+esc(impact.name)+'</b><small>'+fmtCLP(impact.value)+'</small></div><div class="v60-mini" style="background:#eff6ff"><span>Total causas</span><b>'+fmtNum(by.length,0)+'</b><small>categorías</small></div><div class="v60-mini" style="background:#f0fdf4"><span>Top 5 causas</span><b>'+fmtNum(top5,0)+'</b><small>'+(total?fmtNum(top5/total*100,1):'0,0')+'% casos</small></div></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:18px"><div><h3>Pareto de causas</h3>'+by.map((r,i)=>'<div class="v60-bar-row"><div>'+esc(r.name)+'</div><div class="v60-track"><div class="v60-fill" style="width:'+Math.max(4,r.count/maxC*100)+'%;background:'+colorFor(i)+'"></div></div><div class="v60-val">'+fmtNum(r.count,0)+'<br><span style="font-size:11px;color:#64748b">'+(total?fmtNum(r.count/total*100,1):'0,0')+'%</span></div></div>').join('')+'</div><div><h3>Impacto económico por causa ($)</h3><div class="v60-donut-wrap"><div class="v60-donut" style="background:conic-gradient('+(conic||'#e5e7eb 0 100%')+')"><b>'+moneyShort(totalVal)+'<br><span style="font-size:11px;color:#64748b">Total</span></b></div><div>'+by.slice(0,7).map((r,i)=>'<div style="display:flex;justify-content:space-between;gap:8px;margin:8px 0"><span><i class="v60-dot" style="background:'+colorFor(i)+'"></i> '+esc(r.name)+'</span><b>'+fmtCLP(r.value)+'</b></div>').join('')+'</div></div></div></div></div><div><div class="v60-card" style="margin-bottom:16px"><h3>Semáforo gerencial (por causa)</h3><table class="v60-table-clean"><thead><tr><th>Causa</th><th>Casos</th><th>Semáforo</th><th>Responsable</th></tr></thead><tbody>'+by.map((r,i)=>'<tr><td>'+esc(r.name)+'</td><td><b>'+fmtNum(r.count,0)+'</b></td><td><span class="v60-dot" style="background:'+(r.count>20?'#ef2029':r.count>10?'#ff7a1a':'#008f45')+'"></span></td><td>'+esc(r.resp)+'</td></tr>').join('')+'</tbody></table></div><div class="v60-card"><h3>Top 5 comentarios más repetidos</h3><table class="v60-table-clean"><thead><tr><th>Comentario</th><th>Casos</th></tr></thead><tbody>'+comments.map(c=>'<tr><td>'+esc(c.name)+'</td><td><b>'+fmtNum(c.count,0)+'</b></td></tr>').join('')+'</tbody></table></div></div></div></section>';
  }
  window.renderResumen=function(){var loss=S.loss||[], stock=S.stock||[]; var stockValid=stock.filter(r=>!r.obsoleto&&num(r.dias)>=0); var total=sum(loss), kg=sum(loss,'stock'), avg=kg?total/kg:0; var last=window.__v60LastUpdate||safe(()=>document.getElementById('lastUpdateV43').textContent,'—');
    if(!loss.length && !stock.length){return '<section class="section active" id="sec-resumen"><div class="v60-header"><div class="v60-title"><h1>Resumen Ejecutivo</h1><span>Última actualización: <b>'+esc(last||'pendiente')+'</b></span></div><div class="v60-controls"><span class="v60-pill">☁️ Esperando carga GitHub/Vercel</span></div></div><div class="card card-pad"><b>Cargando información centralizada...</b><br><span class="small">Si estás en Vercel, el dashboard leerá automáticamente los 3 archivos desde /datos. Si estás en archivo local, usa Administrador para cargar los Excel manualmente.</span></div></section>'}
    return '<section class="section active" id="sec-resumen"><div class="v60-header"><div class="v60-title"><h1>Resumen Ejecutivo</h1><span>Última actualización: <b>'+esc(last||'—')+'</b> ↻</span></div><div class="v60-controls"><span class="v60-pill">☁️ GitHub/Vercel + carga manual</span><span class="v60-pill"><span class="tiny">Vista</span><button class="v60-btn active" data-view="gerencial">Gerencial</button><button class="v60-btn" data-view="operativa">Operativa</button></span><span class="v60-pill"><span class="tiny">Tabla</span><button class="v60-btn" data-density="compact">Compacta</button><button class="v60-btn active" data-density="normal">Normal</button><button class="v60-btn" data-density="wide">Amplia</button></span><button class="v60-pill v60-full" id="v60FullBtn">↙ Normal</button></div></div><div class="v60-kpi-grid"><div class="v60-kpi"><div class="v60-kpi-icon v60-red">$</div><div><small>Pérdida total</small><b>'+fmtCLP(total).replace('$ ','$')+'</b><span>Costo total de riesgo</span><em class="v60-chip">Histórico cargado</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-orange">📦</div><div><small>Lotes afectados</small><b>'+fmtNum(loss.length,0)+'</b><span>Lotes con pérdida</span><em class="v60-chip ok">Cruce precio '+(loss.filter(r=>r.precio).length?'OK':'pendiente')+'</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-green">KG</div><div><small>Kilos afectados</small><b>'+fmtNum(kg,1)+' KG</b><span>Total kilos con pérdida</span><em class="v60-chip">Stock SAP</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-blue">↗</div><div><small>Costo promedio / KG</small><b>'+fmtCLP(avg).replace('$ ','$')+'</b><span>Promedio ponderado</span><em class="v60-chip">KG × precio OC</em></div></div></div><div class="v60-dashboard-grid"><div class="v60-card"><h3>Pérdida por motivo (Top 5)</h3>'+barsHTML(loss,r=>r.motivo||'Sin motivo',null,5)+'<div class="v60-card-link">Ver detalle completo →</div></div><div class="v60-card"><h3>Pérdida mensual ($)</h3>'+localLineChartByMonth(loss)+'<div class="v60-card-link">Ver análisis mensual →</div></div><div class="v60-card"><h3>Ranking proveedores (pérdida $)</h3>'+barsHTML(loss,r=>r.proveedor||'—',null,5)+'<div class="v60-card-link">Ver detalle proveedores →</div></div></div>'+renderCausasV60().replace('<section class="section active" id="sec-causas"><div class="v60-header"><div class="v60-title"><h1>Causas raíz</h1><span>Análisis gerencial de comentarios, responsables e impacto económico.</span></div></div>','<div>') .replace('</section>','</div>')+'<div class="v60-footer"><span>Los datos presentados corresponden al cruce de Stock SAP + Precios OC + MB51 Fecha ingreso.</span><span>Dashboard Calidad & Costos | Minuto Verde</span></div></section>';
  }
  window.renderStock=function(){var base=(S.stock||[]).filter(r=>!r.obsoleto&&num(r.dias)>=0); var rows=filtered(base,'stock').sort((a,b)=>a.dias-b.dias); var riesgo=rows.filter(r=>r.dias<=30); var q=rows.filter(r=>r.q); var sinPrecio=rows.filter(r=>!r.precio); return '<section class="section active" id="sec-stock"><div class="v60-header"><div class="v60-title"><h1>Calidad / Stock / Vencimientos</h1><span>Vista operativa para seguimiento de lotes, Q, riesgo por días y valorización KG × precio OC.</span></div></div>'+filters('stock','stock')+'<div class="v60-stock-kpis"><div class="v60-stock-kpi"><b>'+fmtNum(rows.length,0)+'</b><span>Registros visibles</span></div><div class="v60-stock-kpi warn"><b>'+fmtNum(riesgo.length,0)+'</b><span>≤ 30 días</span></div><div class="v60-stock-kpi blue"><b>'+fmtNum(q.length,0)+'</b><span>Stock en Q</span></div><div class="v60-stock-kpi danger"><b>'+fmtCLP(sum(rows))+'</b><span>Valor inventario</span></div></div><div class="card"><div class="section-title">Detalle stock y vencimientos · '+fmtNum(rows.length,0)+' registros · Sin precio: '+fmtNum(sinPrecio.length,0)+'</div><div class="table-wrap"><table><thead><tr><th>Estado</th><th>Q</th><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Lote</th><th>Fabricación</th><th>Recepción</th><th>Vencimiento</th><th>Días</th><th>Stock KG</th><th>Precio OC</th><th>Valor</th><th>Motivo / Comentario</th></tr></thead><tbody>'+rows.map(r=>'<tr><td>'+badge(r.estado)+'</td><td>'+(r.q?badge('Q'):badge('Sin Q'))+'</td><td class="c">'+esc(r.mat)+'</td><td class="desc">'+esc(r.desc)+'</td><td class="prov">'+esc(r.proveedor)+'</td><td class="c">'+esc(r.lote)+'</td><td class="c">'+fd(r.fechaCrea)+'</td><td class="c">'+fd(r.fechaIngreso)+'</td><td class="c">'+fd(r.fechaCad)+'</td><td class="r"><b>'+fmtNum(r.dias,0)+'</b></td><td class="r">'+fmtNum(r.stock)+'</td><td class="r">'+(r.precio?fmtCLP(r.precio):'<span style="color:#dc2626;font-weight:950">Sin precio</span>')+'</td><td class="r"><b>'+fmtCLP(r.valor)+'</b></td><td>'+esc(r.comentario||'—')+'</td></tr>').join('')+'</tbody></table></div></div></section>'}
  var oldRenderSection=window.renderSection;
  window.renderSection=function(id){ if(id==='causas') return renderCausasV60(); if(id==='admin') return '<section class="section active" id="sec-admin"><div class="v60-header"><div class="v60-title"><h1>Administrador</h1><span>Carga manual de respaldo y actualización de los 3 archivos base.</span></div></div></section>'; if(id==='resumen') return renderResumen(); if(id==='stock') return renderStock(); return oldRenderSection?oldRenderSection(id):renderResumen(); };
  var oldSetActive=window.setActive;
  window.setActive=function(id){ S.active=id; document.body.classList.toggle('v60-admin',id==='admin'); if(id==='admin'){document.querySelectorAll('#nav button').forEach(b=>b.classList.toggle('active',b.dataset.id===id)); return;} renderAll(); };
  var oldRenderAll=window.renderAll;
  window.renderAll=function(){ document.body.classList.remove('v60-admin'); oldRenderAll(); setTimeout(bindV60Controls,0); };
  function rebuildNav(){
    var nav=document.getElementById('nav'); if(!nav) return;
    SECTIONS.length=0; [['resumen','🏠 Resumen Ejecutivo'],['causas','🎯 Causas Raíz'],['detalle','▦ Detalle de Lotes'],['perdidas','💰 Pérdidas / Costos'],['proveedores','👥 Proveedores'],['motivos','🏷️ Motivos SAP'],['productos','🛒 Compras / Sobrestock'],['stock','📦 Calidad / Stock / Vencimientos'],['q','🔍 Stock Q'],['evaluacion','☑️ Evaluación materiales'],['admin','⚙️ Administrador']].forEach(x=>SECTIONS.push(x));
    nav.innerHTML='<div class="nav-group-title ger">Gerencia</div>'+SECTIONS.slice(0,3).map(([id,t])=>'<button data-id="'+id+'">'+t+'</button>').join('')+'<div class="nav-group-title op">Análisis operativo</div>'+SECTIONS.slice(3,7).map(([id,t])=>'<button data-id="'+id+'">'+t+'</button>').join('')+'<div class="nav-group-title cal">Calidad / Stock / Programación</div>'+SECTIONS.slice(7,10).map(([id,t])=>'<button data-id="'+id+'">'+t+'</button>').join('')+'<div class="nav-group-title adm">Administración</div>'+SECTIONS.slice(10).map(([id,t])=>'<button data-id="'+id+'">'+t+'</button>').join('');
    nav.querySelectorAll('button').forEach(b=>b.onclick=function(){setActive(this.dataset.id)});
  }
  function bindV60Controls(){
    document.querySelectorAll('[data-density]').forEach(btn=>{btn.onclick=function(){setDensity(btn.dataset.density)}});
    var full=document.getElementById('v60FullBtn'); if(full) full.onclick=function(){document.body.classList.toggle('v60-screen'); if(!document.fullscreenElement && document.documentElement.requestFullscreen) document.documentElement.requestFullscreen().catch(()=>{}); else if(document.exitFullscreen) document.exitFullscreen().catch(()=>{});};
  }
  function setDensity(mode){document.body.classList.toggle('table-compact',mode==='compact');document.body.classList.toggle('table-wide',mode==='wide');document.querySelectorAll('[data-density]').forEach(b=>b.classList.toggle('active',b.dataset.density===mode)); try{localStorage.setItem('mvTableDensity',mode)}catch(e){}}
  function updateLast(){var d=new Date(); var pad=n=>String(n).padStart(2,'0'); window.__v60LastUpdate=pad(d.getDate())+'/'+pad(d.getMonth()+1)+'/'+d.getFullYear()+' '+pad(d.getHours())+':'+pad(d.getMinutes()); var el=document.getElementById('lastUpdateV43'); if(el) el.textContent=window.__v60LastUpdate;}
  var oldProcess=window.process; window.process=function(){ var r=oldProcess.apply(this,arguments); updateLast(); return r; };
  var oldAuto=window.autoLoadGithubFiles; if(oldAuto) window.autoLoadGithubFiles=async function(){var r=await oldAuto.apply(this,arguments); updateLast(); return r;};
  var oldApply=window.applyFiles; if(oldApply) window.applyFiles=async function(){var r=await oldApply.apply(this,arguments); updateLast(); return r;};
  ready(function(){ rebuildNav(); updateLast(); setDensity(localStorage.getItem('mvTableDensity')||'normal'); setActive('resumen'); setTimeout(bindV60Controls,400); });
})();

;

(function(){
  function activateCompactOnce(){
    try{
      if(!localStorage.getItem('mvTableDensity')) localStorage.setItem('mvTableDensity','compact');
      document.body.classList.remove('table-wide');
      document.body.classList.add('table-compact');
      document.querySelectorAll('[data-density]').forEach(function(b){b.classList.toggle('active',b.getAttribute('data-density')==='compact');});
    }catch(e){}
  }
  window.addEventListener('load',function(){
    setTimeout(function(){
      try{
        if(localStorage.getItem('mvTableDensity')==='compact') activateCompactOnce();
      }catch(e){}
    },600);
  });
})();

;

(function(){
  function safe(fn,def){try{return fn()}catch(e){return def}}
  function n(v){return Number(v||0)||0}
  function ymName(m){try{if(!/^\d{4}-\d{2}$/.test(m||''))return m||'Sin mes';var p=m.split('-').map(Number);return new Date(p[0],p[1]-1,1).toLocaleDateString('es-CL',{month:'long',year:'numeric'}).replace('.','')}catch(e){return m||'Sin mes'}}
  function money(v){return (typeof fmtCLP==='function')?fmtCLP(v):('$'+Math.round(n(v)).toLocaleString('es-CL'))}
  function number(v,d){return (typeof fmtNum==='function')?fmtNum(v,d):n(v).toLocaleString('es-CL')}
  function html(s){return (typeof esc==='function')?esc(s):String(s??'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]})}
  function total(rows,k){return rows.reduce(function(a,r){return a+n(k?r[k]:r.valor)},0)}
  function groupByMonth(rows){
    var map={}; (rows||[]).forEach(function(r){var m=r.mes||r.mesVenc||'Sin fecha'; if(!map[m])map[m]=[]; map[m].push(r)});
    return Object.keys(map).sort().map(function(m){var rs=map[m];return {mes:m,rows:rs,valor:total(rs),kg:total(rs,'stock'),lotes:rs.length}})
  }
  function currentYM(){
    var d=new Date();
    return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
  }
  function isYM(m){return /^\d{4}-\d{2}$/.test(m||'')}
  function untilCurrentMonth(data){
    var today=currentYM();
    return (data||[]).filter(function(d){return isYM(d.mes) && d.mes<=today});
  }

  function localColor(i){return ['#ef2029','#ff7a1a','#ffc928','#8b5cf6','#2d74f0','#00964b','#64748b'][i%7]}
  function localGroup(rows,fn){var m={};(rows||[]).forEach(function(r){var k=(fn?fn(r):'Sin grupo')||'Sin grupo';(m[k]=m[k]||[]).push(r)});return m;}
  function localMax(arr,k){return Math.max(1,...(arr||[]).map(function(x){return n(x[k])}))}
  function localBarsHTML(rows, groupFn, valueFn, limit){
    var g=localGroup(rows,groupFn); var arr=Object.keys(g).map(function(k){return {name:k,value:valueFn?valueFn(g[k]):total(g[k]),count:g[k].length,kg:total(g[k],'stock')}}).sort(function(a,b){return b.value-a.value}).slice(0,limit||5);
    var mx=localMax(arr,'value'); if(!arr.length) return '<div class="empty">Sin datos</div>';
    return arr.map(function(r,i){return '<div class="v60-bar-row"><div>'+html(r.name)+'</div><div class="v60-track"><div class="v60-fill" style="width:'+Math.max(4,(r.value/mx*100))+'%;background:'+localColor(i)+'"></div></div><div class="v60-val">'+money(r.value).replace('$ ','$')+'<br><span style="color:#64748b;font-size:11px">'+number(r.count,0)+' casos</span></div></div>'}).join('');
  }
  function localLineChartByMonth(rows){
    var data=groupByMonth(rows).filter(function(d){return d.mes && d.mes!=='Sin fecha'}).slice(-12);
    if(!data.length) return '<div class="empty">Sin datos</div>';
    var W=620,H=180,p=18,max=Math.max(1,...data.map(function(d){return d.valor}));
    var pts=data.map(function(d,i){var x=p+(i*(W-2*p)/Math.max(1,data.length-1)); var y=H-p-(d.valor/max)*(H-2*p); return [x,y,d];});
    var poly=pts.map(function(p){return p[0]+','+p[1]}).join(' ');
    var area='M'+pts[0][0]+','+(H-p)+' L'+pts.map(function(p){return p[0]+','+p[1]}).join(' L')+' L'+pts[pts.length-1][0]+','+(H-p)+' Z';
    var labels=pts.map(function(p){return '<text x="'+p[0]+'" y="176" text-anchor="middle" font-size="11" fill="#334155">'+html(String(p[2].mes).slice(5))+'</text>'}).join('');
    var circles=pts.map(function(p){return '<circle cx="'+p[0]+'" cy="'+p[1]+'" r="4" fill="#fff" stroke="#ef2029" stroke-width="3"><title>'+html(p[2].mes+' · '+money(p[2].valor))+'</title></circle>'}).join('');
    return '<div class="v60-linechart"><svg viewBox="0 0 '+W+' '+H+'" preserveAspectRatio="none"><path d="'+area+'" fill="rgba(239,32,41,.12)"/><polyline points="'+poly+'" fill="none" stroke="#ef2029" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>'+circles+labels+'</svg></div>';
  }

  function selectedMonth(){return safe(function(){return localStorage.getItem('mv62SelectedMonth')||''},'')}
  function setSelectedMonth(m){try{localStorage.setItem('mv62SelectedMonth',m||'')}catch(e){}}
  function openLotsByMonth(m){
    if(!m || m==='Todos') return;
    setSelectedMonth(m);
    S.filters.detalle=S.filters.detalle||{};
    S.filters.detalle.mes=m;
    delete S.filters.detalle.dateFrom; delete S.filters.detalle.dateTo;
    S.active='detalle';
    if(typeof renderAll==='function') renderAll();
    setTimeout(function(){document.getElementById('sec-detalle')?.scrollIntoView({behavior:'smooth',block:'start'});},80);
  }
  window.v62OpenLotsByMonth=openLotsByMonth;
  window.v62SelectMonth=function(m){setSelectedMonth(m); if(typeof renderAll==='function')renderAll();};
  window.v62ClearMonth=function(){setSelectedMonth(''); ['detalle','perdidas','proveedores','motivos'].forEach(function(sc){S.filters[sc]=S.filters[sc]||{};delete S.filters[sc].mes;}); if(typeof renderAll==='function')renderAll();};
  function interactiveChart(data,sel){
    var onlyUntilToday=untilCurrentMonth(data);
    if(!onlyUntilToday.length)return '<div class="empty">Sin datos mensuales hasta el mes actual.</div>';
    var view=onlyUntilToday.slice(-12); var W=920,H=330,pL=62,pR=38,pT=38,pB=58,innerW=W-pL-pR,innerH=H-pT-pB;
    var maxVal=Math.max(1,...view.map(d=>d.valor)); var step=innerW/view.length; var bw=Math.max(22,Math.min(54,step*.58));
    var grid=[0,.25,.5,.75,1].map(function(t){var y=pT+innerH*(1-t);return '<line x1="'+pL+'" y1="'+y+'" x2="'+(W-pR)+'" y2="'+y+'" stroke="#e2e8f0"/>'}).join('');
    var bars=view.map(function(d,i){var x=pL+i*step+step/2, h=d.valor/maxVal*innerH, y=pT+innerH-h, isSel=d.mes===sel; var fill=isSel?'#ef2029':'#00843d';
      return '<g class="v62-bar" onclick="v62OpenLotsByMonth(\''+html(d.mes)+'\')"><rect x="'+(x-bw/2).toFixed(1)+'" y="'+y.toFixed(1)+'" width="'+bw.toFixed(1)+'" height="'+Math.max(5,h).toFixed(1)+'" rx="9" fill="'+fill+'" opacity="'+(isSel?'.96':'.78')+'"><title>'+html(ymName(d.mes))+' · '+money(d.valor)+' · '+number(d.kg,1)+' KG · '+number(d.lotes,0)+' lotes · Click para ver lotes</title></rect><text x="'+x.toFixed(1)+'" y="'+Math.max(18,y-7).toFixed(1)+'" text-anchor="middle" font-size="10" fill="#061323" font-weight="950">'+(d.valor?('$'+Math.round(d.valor/1000000).toLocaleString('es-CL')+'M'):'$0')+'</text><text x="'+x.toFixed(1)+'" y="'+(H-29)+'" text-anchor="middle" font-size="11" fill="'+(isSel?'#ef2029':'#334155')+'" font-weight="950">'+html(String(d.mes).slice(5))+'</text><text x="'+x.toFixed(1)+'" y="'+(H-14)+'" text-anchor="middle" font-size="10" fill="#64748b">'+html(String(d.mes).slice(0,4))+'</text></g>';
    }).join('');
    return '<div class="v62-svg-wrap"><svg viewBox="0 0 '+W+' '+H+'">'+grid+'<line x1="'+pL+'" y1="'+(pT+innerH)+'" x2="'+(W-pR)+'" y2="'+(pT+innerH)+'" stroke="#cbd5e1"/><line x1="'+pL+'" y1="'+pT+'" x2="'+pL+'" y2="'+(pT+innerH)+'" stroke="#cbd5e1"/>'+bars+'<text x="'+pL+'" y="20" font-size="13" fill="#061323" font-weight="950">Pérdida mensual por fecha de vencimiento</text><text x="'+(W-pR)+'" y="20" text-anchor="end" font-size="11" fill="#64748b">Click en barra = ver lotes</text></svg></div>';
  }
  function previewRows(rows){
    var top=(rows||[]).slice().sort(function(a,b){return n(b.valor)-n(a.valor)}).slice(0,8);
    if(!top.length)return '<div class="empty">Selecciona un mes para previsualizar los principales lotes.</div>';
    return '<div class="v62-table-preview"><table><thead><tr><th>Material</th><th>Descripción</th><th>Proveedor</th><th>Lote</th><th>KG</th><th>Valor</th></tr></thead><tbody>'+top.map(function(r){return '<tr><td>'+html(r.mat)+'</td><td class="desc">'+html(r.desc)+'</td><td>'+html(r.proveedor)+'</td><td>'+html(r.lote)+'</td><td class="r">'+number(r.stock,1)+'</td><td class="r"><b>'+money(r.valor)+'</b></td></tr>'}).join('')+'</tbody></table></div>';
  }
  function monthModule(rows){
    var dataAll=groupByMonth(rows);
    var data=untilCurrentMonth(dataAll);
    var sel=selectedMonth();
    if(sel && !data.some(function(d){return d.mes===sel})) sel='';
    var selected=sel?data.find(function(d){return d.mes===sel}):data[data.length-1];
    if(!selected)selected={mes:'',rows:[],valor:0,kg:0,lotes:0};
    var options='<option value="">Seleccionar mes hasta hoy...</option>'+data.slice().reverse().map(function(d){return '<option value="'+html(d.mes)+'" '+(d.mes===selected.mes?'selected':'')+'>'+html(ymName(d.mes))+' · '+money(d.valor)+'</option>'}).join('');
    var chips=data.slice(-6).reverse().map(function(d){return '<button type="button" class="v62-month-chip '+(d.mes===selected.mes?'active':'')+'" onclick="v62SelectMonth(\''+html(d.mes)+'\')">📅 '+html(ymName(d.mes))+'</button>'}).join('');
    return '<div class="v62-month-panel"><div class="v62-card"><h3>📊 Gráfico interactivo mensual</h3><div class="v62-sub">Muestra solo meses hasta la fecha actual. Haz click en una barra para abrir automáticamente el detalle de lotes filtrado.</div>'+interactiveChart(dataAll,selected.mes)+'<div class="v62-hint">Mes seleccionado: <b>'+html(ymName(selected.mes))+'</b>. En este gráfico se excluyen vencimientos futuros; el detalle completo sigue disponible en Detalle Lotes.</div></div><div class="v62-card"><h3>🔎 Ver lotes por mes</h3><div class="v62-toolbar"><div class="v62-field"><label>Mes de vencimiento</label><select id="v62MonthSelect">'+options+'</select></div><button type="button" class="v62-btn" id="v62OpenMonthBtn">Ver lotes</button><button type="button" class="v62-btn gray" onclick="v62ClearMonth()">Limpiar</button></div><div class="v62-selected"><div class="v62-mini"><b>'+money(selected.valor)+'</b><span>Valor mes</span></div><div class="v62-mini"><b>'+number(selected.kg,1)+' KG</b><span>Kilos mes</span></div><div class="v62-mini"><b>'+number(selected.lotes,0)+'</b><span>Lotes mes</span></div></div><div class="v62-month-list">'+chips+'</div>'+previewRows(selected.rows)+'<button type="button" class="v62-btn dark" style="margin-top:10px;width:100%" onclick="v62OpenLotsByMonth(\''+html(selected.mes)+'\')">Abrir detalle de lotes filtrado</button></div></div>';
  }
  function bindV62(){
    var sel=document.getElementById('v62MonthSelect'); if(sel&&!sel.__v62){sel.__v62=true; sel.addEventListener('change',function(){window.v62SelectMonth(this.value)});}
    var btn=document.getElementById('v62OpenMonthBtn'); if(btn&&!btn.__v62){btn.__v62=true; btn.addEventListener('click',function(){var s=document.getElementById('v62MonthSelect'); if(s&&s.value)openLotsByMonth(s.value)});}
  }
  var previousRenderResumen=window.renderResumen;
  window.renderResumen=function(){
    var loss=safe(function(){return S.loss||[]},[]), stock=safe(function(){return S.stock||[]},[]);
    var stockValid=stock.filter(function(r){return !r.obsoleto&&n(r.dias)>=0}); var totalVal=total(loss), kg=total(loss,'stock'), avg=kg?totalVal/kg:0; var last=window.__v60LastUpdate||safe(function(){return document.getElementById('lastUpdateV43').textContent},'—');
    if(!loss.length && !stock.length) return previousRenderResumen?previousRenderResumen():'';
    var base='<section class="section active" id="sec-resumen"><div class="v60-header"><div class="v60-title"><h1>Resumen Ejecutivo</h1><span>Última actualización: <b>'+html(last||'—')+'</b> ↻</span></div><div class="v60-controls"><span class="v60-pill">☁️ GitHub/Vercel + carga manual</span><span class="v60-pill"><span class="tiny">Tabla</span><button class="v60-btn" data-density="compact">Compacta</button><button class="v60-btn active" data-density="normal">Normal</button><button class="v60-btn" data-density="wide">Amplia</button></span><button class="v60-pill v60-full" id="v60FullBtn">Pantalla completa</button></div></div><div class="v60-kpi-grid"><div class="v60-kpi"><div class="v60-kpi-icon v60-red">$</div><div><small>Pérdida total</small><b>'+money(totalVal).replace('$ ','$')+'</b><span>Costo total de riesgo</span><em class="v60-chip">Histórico cargado</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-orange">📦</div><div><small>Lotes afectados</small><b>'+number(loss.length,0)+'</b><span>Lotes con pérdida</span><em class="v60-chip ok">Cruce precio '+(loss.filter(function(r){return r.precio}).length?'OK':'pendiente')+'</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-green">KG</div><div><small>Kilos afectados</small><b>'+number(kg,1)+' KG</b><span>Total kilos con pérdida</span><em class="v60-chip">Stock SAP</em></div></div><div class="v60-kpi"><div class="v60-kpi-icon v60-blue">↗</div><div><small>Costo promedio / KG</small><b>'+money(avg).replace('$ ','$')+'</b><span>Promedio ponderado</span><em class="v60-chip">KG × precio OC</em></div></div></div>'+monthModule(loss)+'<div class="v60-dashboard-grid"><div class="v60-card"><h3>Pérdida por motivo (Top 5)</h3>'+localBarsHTML(loss,function(r){return r.motivo||'Sin motivo'},null,5)+'<div class="v60-card-link" onclick="setActive(\'motivos\')" style="cursor:pointer">Ver detalle completo →</div></div><div class="v60-card"><h3>Pérdida mensual ($)</h3>'+localLineChartByMonth(loss)+'<div class="v60-card-link">Usa el gráfico interactivo superior para abrir lotes →</div></div><div class="v60-card"><h3>Ranking proveedores (pérdida $)</h3>'+localBarsHTML(loss,function(r){return r.proveedor||'—'},null,5)+'<div class="v60-card-link" onclick="setActive(\'proveedores\')" style="cursor:pointer">Ver detalle proveedores →</div></div></div>';
    var causas=safe(function(){return renderCausasV60().replace('<section class="section active" id="sec-causas"><div class="v60-header"><div class="v60-title"><h1>Causas raíz</h1><span>Análisis gerencial de comentarios, responsables e impacto económico.</span></div></div>','<div>').replace('</section>','</div>')},'');
    return base+causas+'<div class="v60-footer"><span>Los datos presentados corresponden al cruce de Stock SAP + Precios OC + MB51 Fecha ingreso.</span><span>Dashboard Calidad & Costos | Minuto Verde</span></div></section>';
  };
  var oldRenderAll=window.renderAll;
  if(typeof oldRenderAll==='function'&&!oldRenderAll.__v62){window.renderAll=function(){var r=oldRenderAll.apply(this,arguments);setTimeout(bindV62,0);return r};window.renderAll.__v62=true;}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',function(){setTimeout(bindV62,500)});else setTimeout(bindV62,500);
})();

;

(function(){
  const KEY='mvV63TableSizing';
  const DEF={font:10.2,pady:3,padx:5,line:1.12,desc:210,prov:170,height:72,ultra:false,wrap:false,mini:false};
  function load(){try{return Object.assign({},DEF,JSON.parse(localStorage.getItem(KEY)||'{}'))}catch(e){return Object.assign({},DEF)}}
  function save(c){try{localStorage.setItem(KEY,JSON.stringify(c))}catch(e){}}
  function setVar(n,v,u){document.documentElement.style.setProperty(n,v+u)}
  function apply(c){
    document.body.classList.add('v63-table-advanced');
    document.body.classList.toggle('v63-ultra',!!c.ultra);
    document.body.classList.toggle('v63-wrap-text',!!c.wrap);
    setVar('--v63-table-font',c.font,'px');setVar('--v63-table-pady',c.pady,'px');setVar('--v63-table-padx',c.padx,'px');setVar('--v63-row-line',c.line,'');setVar('--v63-desc-width',c.desc,'px');setVar('--v63-prov-width',c.prov,'px');setVar('--v63-table-height',c.height,'vh');
    updateOutputs(c); makeResizable();
    const p=document.getElementById('v63SizePanel'); if(p) p.classList.toggle('v63-mini',!!c.mini);
  }
  function panel(c){return `<div class="v63-size-panel ${c.mini?'v63-mini':''}" id="v63SizePanel"><div class="v63-head"><div><b>📏 Tamaño tablas</b><span>Fuente, filas, columnas y altura</span></div><button class="v63-toggle" id="v63Mini" title="Minimizar">${c.mini?'⚙️':'−'}</button></div><div class="v63-body">
    <div class="v63-row"><label>Fuente</label><input id="v63Font" type="range" min="8" max="13" step="0.1" value="${c.font}"><output id="v63FontOut"></output></div>
    <div class="v63-row"><label>Alto fila</label><input id="v63PadY" type="range" min="1" max="8" step="1" value="${c.pady}"><output id="v63PadYOut"></output></div>
    <div class="v63-row"><label>Ancho fila</label><input id="v63PadX" type="range" min="3" max="12" step="1" value="${c.padx}"><output id="v63PadXOut"></output></div>
    <div class="v63-row"><label>Descripción</label><input id="v63Desc" type="range" min="140" max="420" step="10" value="${c.desc}"><output id="v63DescOut"></output></div>
    <div class="v63-row"><label>Proveedor</label><input id="v63Prov" type="range" min="120" max="360" step="10" value="${c.prov}"><output id="v63ProvOut"></output></div>
    <div class="v63-row"><label>Altura</label><input id="v63Height" type="range" min="45" max="86" step="1" value="${c.height}"><output id="v63HeightOut"></output></div>
    <div class="v63-actions"><button class="green" id="v63Ultra">Ultra compacto</button><button class="gray" id="v63Wrap">Texto filas</button><button class="red" id="v63Reset">Reset</button></div>
    <div class="v63-note">Tip: también puedes arrastrar el borde derecho de cada encabezado para ajustar columnas específicas.</div>
  </div></div>`}
  function getFromInputs(){let c=load();
    const val=(id,old)=>{const e=document.getElementById(id);return e?Number(e.value):old};
    c.font=val('v63Font',c.font);c.pady=val('v63PadY',c.pady);c.padx=val('v63PadX',c.padx);c.desc=val('v63Desc',c.desc);c.prov=val('v63Prov',c.prov);c.height=val('v63Height',c.height); return c;
  }
  function updateOutputs(c){
    const map={v63FontOut:c.font.toFixed(1),v63PadYOut:c.pady+'px',v63PadXOut:c.padx+'px',v63DescOut:c.desc+'px',v63ProvOut:c.prov+'px',v63HeightOut:c.height+'vh'};
    Object.entries(map).forEach(([id,val])=>{const e=document.getElementById(id); if(e)e.textContent=val});
    const u=document.getElementById('v63Ultra'), w=document.getElementById('v63Wrap'); if(u)u.textContent=c.ultra?'Ultra ON':'Ultra compacto'; if(w)w.textContent=c.wrap?'Texto ON':'Texto filas';
  }
  function inject(){
    let c=load(); if(!document.getElementById('v63SizePanel')) document.body.insertAdjacentHTML('beforeend',panel(c));
    ['v63Font','v63PadY','v63PadX','v63Desc','v63Prov','v63Height'].forEach(id=>{const el=document.getElementById(id); if(el&&!el.dataset.bound){el.dataset.bound='1'; el.addEventListener('input',()=>{let n=getFromInputs(); n.ultra=load().ultra; n.wrap=load().wrap; n.mini=false; save(n); apply(n);});}});
    const ultra=document.getElementById('v63Ultra'); if(ultra&&!ultra.dataset.bound){ultra.dataset.bound='1'; ultra.onclick=()=>{let n=getFromInputs(); n.ultra=!load().ultra; n.wrap=load().wrap; n.mini=false; save(n); apply(n);};}
    const wrap=document.getElementById('v63Wrap'); if(wrap&&!wrap.dataset.bound){wrap.dataset.bound='1'; wrap.onclick=()=>{let n=getFromInputs(); n.wrap=!load().wrap; n.ultra=load().ultra; n.mini=false; save(n); apply(n);};}
    const reset=document.getElementById('v63Reset'); if(reset&&!reset.dataset.bound){reset.dataset.bound='1'; reset.onclick=()=>{save(Object.assign({},DEF)); document.getElementById('v63SizePanel')?.remove(); inject(); apply(load());};}
    const mini=document.getElementById('v63Mini'); if(mini&&!mini.dataset.bound){mini.dataset.bound='1'; mini.onclick=()=>{let n=load(); n.mini=!n.mini; save(n); document.getElementById('v63SizePanel')?.remove(); inject(); apply(load());};}
    apply(c);
  }
  const colWidths={};
  function tableKey(table){const sec=table.closest('.section')?.id||'global'; const idx=[...document.querySelectorAll('#'+CSS.escape(sec)+' table')].indexOf(table); return sec+'::'+idx;}
  function makeResizable(){
    document.querySelectorAll('.table-wrap table').forEach(table=>{
      const key=tableKey(table);
      table.querySelectorAll('th').forEach((th,i)=>{
        th.classList.add('v63-resizable');
        const saved=localStorage.getItem('mvV63col_'+key+'_'+i); if(saved){th.style.minWidth=saved+'px'; th.style.width=saved+'px'; table.querySelectorAll('tr').forEach(tr=>{const cell=tr.children[i]; if(cell){cell.style.minWidth=saved+'px'; cell.style.width=saved+'px';}})}
        if(!th.querySelector('.v63-resizer')){const h=document.createElement('span'); h.className='v63-resizer'; th.appendChild(h); h.addEventListener('mousedown',start); h.addEventListener('touchstart',start,{passive:false});}
        function start(ev){ev.preventDefault(); ev.stopPropagation(); const sx=(ev.touches?ev.touches[0].clientX:ev.clientX); const sw=th.offsetWidth; th.classList.add('v63-resizing');
          function move(e){const x=(e.touches?e.touches[0].clientX:e.clientX); const w=Math.max(48,sw+(x-sx)); th.style.minWidth=w+'px'; th.style.width=w+'px'; table.querySelectorAll('tr').forEach(tr=>{const cell=tr.children[i]; if(cell){cell.style.minWidth=w+'px'; cell.style.width=w+'px';}})}
          function up(){th.classList.remove('v63-resizing'); localStorage.setItem('mvV63col_'+key+'_'+i,parseInt(th.style.width||th.offsetWidth,10)); document.removeEventListener('mousemove',move); document.removeEventListener('mouseup',up); document.removeEventListener('touchmove',move); document.removeEventListener('touchend',up);}
          document.addEventListener('mousemove',move); document.addEventListener('mouseup',up); document.addEventListener('touchmove',move,{passive:false}); document.addEventListener('touchend',up);
        }
      });
    });
  }
  function boot(){inject(); setTimeout(makeResizable,250);}
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',boot); else boot();
  ['renderAll','setActive'].forEach(fn=>{if(typeof window[fn]==='function'&&!window[fn].v63wrap){const old=window[fn]; window[fn]=function(){const r=old.apply(this,arguments); setTimeout(()=>{inject();makeResizable()},120); return r}; window[fn].v63wrap=true;}});
  const obs=new MutationObserver(()=>{clearTimeout(window.__v63mo); window.__v63mo=setTimeout(()=>{apply(load());},150)});
  try{obs.observe(document.body,{childList:true,subtree:true});}catch(e){}
})();

;

(function(){
  const KEY='mvV64FreezeCols';
  function removeOldControls(){
    document.querySelectorAll('.mv33-view-panel').forEach(e=>e.remove());
    document.querySelectorAll('.v60-pill').forEach(p=>{if(p.querySelector('[data-density]')) p.remove();});
  }
  function enabled(){return localStorage.getItem(KEY)!=='0';}
  function setEnabled(v){localStorage.setItem(KEY,v?'1':'0'); document.body.classList.toggle('v64-freeze-on',v); refreshFreeze(); updateBtn();}
  function ensureButton(){
    const panel=document.getElementById('v63SizePanel'); if(!panel) return;
    const actions=panel.querySelector('.v63-actions'); if(!actions) return;
    if(!document.getElementById('v64FreezeBtn')){
      const b=document.createElement('button');
      b.type='button'; b.id='v64FreezeBtn'; b.className='gray v64-freeze-btn';
      b.textContent='Columnas fijas';
      b.onclick=function(){setEnabled(!enabled());};
      actions.insertBefore(b, actions.firstChild);
    }
    updateBtn();
  }
  function updateBtn(){const b=document.getElementById('v64FreezeBtn'); if(b){b.classList.toggle('on',enabled()); b.textContent=enabled()?'Columnas fijas ON':'Columnas fijas';}}
  function clearFreeze(table){
    table.querySelectorAll('.v64-frozen-cell').forEach(c=>{c.classList.remove('v64-frozen-cell'); c.style.left='';});
  }
  function refreshFreeze(){
    document.body.classList.toggle('v64-freeze-on',enabled());
    document.querySelectorAll('.table-wrap table').forEach(table=>{
      clearFreeze(table);
      if(!enabled()) return;
      const rows=[...table.rows]; if(!rows.length) return;
      // Congela las primeras 3 columnas para mantener material/descripcion/proveedor visibles según cada tabla.
      const first=rows[0]; const max=Math.min(3, first.cells.length);
      let left=0;
      for(let i=0;i<max;i++){
        const w=Math.max(48, first.cells[i].getBoundingClientRect().width || first.cells[i].offsetWidth || 90);
        rows.forEach(r=>{const c=r.cells[i]; if(c){c.classList.add('v64-frozen-cell'); c.style.left=left+'px';}});
        left+=w;
      }
    });
  }
  function boot(){removeOldControls(); ensureButton(); setEnabled(enabled()); setTimeout(refreshFreeze,250);}
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',boot); else boot();
  ['renderAll','setActive'].forEach(fn=>{if(typeof window[fn]==='function'&&!window[fn].v64wrap){const old=window[fn]; window[fn]=function(){const r=old.apply(this,arguments); setTimeout(boot,160); return r}; window[fn].v64wrap=true;}});
  window.addEventListener('resize',()=>{clearTimeout(window.__v64rz); window.__v64rz=setTimeout(refreshFreeze,120);});
  const obs=new MutationObserver(()=>{clearTimeout(window.__v64mo); window.__v64mo=setTimeout(boot,180);});
  try{obs.observe(document.body,{childList:true,subtree:true});}catch(e){}
})();
