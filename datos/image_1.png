(function(){
  var AUTH_EMAILS = [
    'ctroncoso@minutoverde.cl',
    'catroncosoj@gmail.com',
    'abarrera@minutoverde.cl',
    'rgubelin@minutoverde.cl',
    'gconcha@minutoverde.cl'
  ];
  var AUTH_PASSWORD = 'programacion2026';

  function setAuthOk(){
    try{
      localStorage.setItem('mvAuthOk','1');
      localStorage.setItem('mvAuth','true');
    }catch(e){}
    document.body.classList.add('auth-ok');
  }

  function logout(){
    try{
      localStorage.removeItem('mvAuthOk');
      localStorage.removeItem('mvAuth');
      sessionStorage.removeItem('mvAuthOk');
      sessionStorage.removeItem('mvAuth');
    }catch(e){}
    document.body.classList.remove('auth-ok');
    location.reload();
  }

  function initMVLogin(){
    try{
      if(localStorage.getItem('mvAuthOk') === '1' || localStorage.getItem('mvAuth') === 'true'){
        document.body.classList.add('auth-ok');
      }
    }catch(e){}

    var form = document.getElementById('loginFormMV');
    var err = document.getElementById('loginErrorMV');
    if(form){
      form.onsubmit = function(ev){
        ev.preventDefault();
        var email = (document.getElementById('loginEmailMV') || {}).value || '';
        var pass = (document.getElementById('loginPasswordMV') || {}).value || '';
