/* === OPTIMIZACIÓN BUSCADORES / FILTROS === */
(function(){
  function debounce(fn, wait){
    var t;
    return function(){
      var ctx=this, args=arguments;
      clearTimeout(t);
      t=setTimeout(function(){ fn.apply(ctx,args); }, wait);
    };
  }

  function initSearchOptimization(){
    var selectors = [
      'input[type="search"]',
      'input[id*="search" i]',
      'input[id*="buscar" i]',
      'input[placeholder*="buscar" i]',
      'input[placeholder*="producto" i]',
      'input[placeholder*="proveedor" i]',
      'input[placeholder*="lote" i]',
      'input[placeholder*="material" i]'
    ].join(",");

    document.querySelectorAll(selectors).forEach(function(el){
      if(el.__mvOptimized) return;
      el.__mvOptimized = true;

      var oldOnInput = el.oninput;
      if(typeof oldOnInput === "function"){
        el.oninput = debounce(function(ev){
          oldOnInput.call(el, ev);
        }, 120);
      }
    });
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", initSearchOptimization);
  }else{
    initSearchOptimization();
  }
  setTimeout(initSearchOptimization, 500);
  setTimeout(initSearchOptimization, 1500);
})();

;

/* === FILTRO POR FECHA GLOBAL SOBRE LOS DATOS CARGADOS === */
(function(){
  function parseAnyDate(v){
    if(v == null || v === "") return null;
    if(v instanceof Date && !isNaN(v)) return v;
    if(typeof v === "number"){
      var d = new Date(Math.round((v - 25569) * 86400000));
      return isNaN(d) ? null : d;
    }
    var s = String(v).trim();
    if(!s) return null;

    // dd/mm/yyyy o dd-mm-yyyy
    var m = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})/);
    if(m){
      var yy = Number(m[3]);
      if(yy < 100) yy += 2000;
      var d1 = new Date(yy, Number(m[2])-1, Number(m[1]));
      return isNaN(d1) ? null : d1;
    }

    var d2 = new Date(s);
    return isNaN(d2) ? null : d2;
  }

  function toDay(d){
    if(!d) return null;
    return new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
  }

  function rowDate(row, mode){
    var keys;
    if(mode === "mov") keys = ["Fecha Movimiento","Fecha movimiento","Fecha Registro","Mes Registro SAP"];
    else if(mode === "venc") keys = ["FeCaduc/FePreferCons","Fecha Vencimiento","Fecha vencimiento","Vencimiento"];
    else if(mode === "precio") keys = ["Fecha Últ. Precio","Fecha Ult. Precio","Fecha documento","Fecha Último Precio"];
    else keys = ["Fecha Movimiento","Fecha movimiento","Fecha Registro","Mes Registro SAP","FeCaduc/FePreferCons","Fecha Vencimiento","Fecha vencimiento"];

    for(var i=0;i<keys.length;i++){
      if(Object.prototype.hasOwnProperty.call(row, keys[i])){
        var d = parseAnyDate(row[keys[i]]);
        if(d) return d;
      }
    }
    return null;
  }

  function dateFilterActive(){
    var from = document.getElementById("mvDateFrom")?.value;
    var to = document.getElementById("mvDateTo")?.value;
    return !!(from || to);
  }

  function applyDateFilterToRows(rows){
    if(!Array.isArray(rows) || !dateFilterActive()) return rows;
    var mode = document.getElementById("mvDateField")?.value || "auto";
    var fromVal = document.getElementById("mvDateFrom")?.value;
    var toVal = document.getElementById("mvDateTo")?.value;
    var from = fromVal ? toDay(parseAnyDate(fromVal)) : null;
    var to = toVal ? toDay(parseAnyDate(toVal)) : null;

    var filtered = rows.filter(function(r){
      var d = rowDate(r, mode);
      if(!d) return false;
      var t = toDay(d);
      if(from != null && t < from) return false;
      if(to != null && t > to) return false;
      return true;
    });

    var st = document.getElementById("mvDateStatus");
    if(st) st.textContent = "Filtro fecha aplicado: " + filtered.length.toLocaleString("es-CL") + " registros.";
    return filtered;
  }

  function installXlsxPatch(){
    if(!window.XLSX || !XLSX.utils || !XLSX.utils.sheet_to_json || XLSX.utils.sheet_to_json.__mvDatePatched) return;
    var original = XLSX.utils.sheet_to_json;
    XLSX.utils.sheet_to_json = function(){
      var rows = original.apply(this, arguments);
      // Solo filtra arrays de objetos, no header:1 ni tablas auxiliares.
      if(Array.isArray(rows) && rows.length && rows[0] && typeof rows[0] === "object" && !Array.isArray(rows[0])){
        return applyDateFilterToRows(rows);
      }
      return rows;
    };
    XLSX.utils.sheet_to_json.__mvDatePatched = true;
  }

  function bindDateButtons(){
    var apply = document.getElementById("mvApplyDateFilter");
    var clear = document.getElementById("mvClearDateFilter");
    if(apply && !apply.__mvBound){
      apply.__mvBound = true;
      apply.onclick = function(){
        var st = document.getElementById("mvDateStatus");
        if(st) st.textContent = "Filtro fecha listo. Vuelve a presionar Aplicar archivo para recalcular.";
      };
    }
    if(clear && !clear.__mvBound){
      clear.__mvBound = true;
      clear.onclick = function(){
        var f = document.getElementById("mvDateFrom");
        var t = document.getElementById("mvDateTo");
        if(f) f.value = "";
        if(t) t.value = "";
        var st = document.getElementById("mvDateStatus");
        if(st) st.textContent = "Sin filtro de fecha aplicado.";
      };
    }
  }

  function init(){
    installXlsxPatch();
    bindDateButtons();
  }

  if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
  setTimeout(init, 300);
  setTimeout(init, 1000);
})();

;

/* === V15 PORTADA EJECUTIVA, GRÁFICO COMBINADO Y TABLAS SIN ÚLTIMO PRECIO === */
(function(){
  function parseDate(v){
    if(v==null || v==="") return null;
    if(v instanceof Date && !isNaN(v)) return v;
    if(typeof v==="number"){
      var d=new Date(Math.round((v-25569)*86400000));
      return isNaN(d)?null:d;
    }
    var s=String(v).trim();
    if(!s || s==="—") return null;
    var m=s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})/);
    if(m){var y=+m[3]; if(y<100)y+=2000; var d1=new Date(y,+m[2]-1,+m[1]); return isNaN(d1)?null:d1;}
    var d2=new Date(s); return isNaN(d2)?null:d2;
  }
  function day(d){d=parseDate(d);return d?new Date(d.getFullYear(),d.getMonth(),d.getDate()):null}
  function diffDays(a,b){a=day(a);b=day(b);return a&&b?Math.round((b-a)/86400000):null}
  function months(d){return d==null?null:+(d/30.4375).toFixed(1)}
  function ym(d){d=parseDate(d);return d?d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"):"Sin fecha"}
  function fmtMoney(n){return "$ "+Math.round(Number(n||0)).toLocaleString("es-CL")}
  function fmtShort(n){n=Number(n||0);return "$"+(n>=1e6?(n/1e6).toFixed(1)+"MM":n>=1e3?(n/1e3).toFixed(0)+"K":Math.round(n).toLocaleString("es-CL"))}
  function fmtKg(n){return Number(n||0).toLocaleString("es-CL",{maximumFractionDigits:1})+" KG"}
  function fmtDate(d){d=parseDate(d);return d?d.toLocaleDateString("es-CL"):"—"}
  function num(v){if(typeof v==="number")return v;let n=parseFloat(String(v??"").replace(/\$/g,"").replace(/\./g,"").replace(",","."));return isNaN(n)?0:n}
  function first(r,keys){for(let k of keys){if(r&&r[k]!=null&&r[k]!=="")return r[k]}return null}
  function clean(s){return String(s??"—").trim()}
  function enrich(r){
    if(!r||typeof r!=="object")return r;
    r.mat=clean(r.mat||r.Material);
    r.desc=clean(r.desc||r["Descrip. Material"]||r["Descripción"]||r["Descripcion"]);
    r.proveedor=clean(r.proveedor||r["Nombre Proveedor"]||r.Proveedor);
    r.lote=clean(r.lote||r.Lote);
    r.fechaVenc=parseDate(r.fechaVenc||first(r,["FeCaduc/FePreferCons","Fecha Vencimiento","Fecha vencimiento","Vencimiento"]));
    r.fechaIngreso=parseDate(r.fechaIngreso||first(r,["Fe.contabilización","Fe.contabilizacion","Fecha contabilización","Fecha contabilizacion"]));
    r.fechaCreacionLote=parseDate(first(r,["Fe.fabricación","Fecha Fabricación","Fecha fabricacion","Fecha Fabricacion"])||r.fechaCreacionLote);
    r.fechaMov=parseDate(r.fechaMov||first(r,["Fecha Movimiento","Fecha movimiento","Fecha Registro"]));
    r.cantKG=num(r.cantKG||r["Stock total"]||r["Cantidad (KG)"]||r.Peso);
    r.diasDuracion=num(r.diasDuracion||first(r,["Días Duración","Dias Duración","Días Duracion","Dias Duracion"]));
    r.valor=num(r.valor||r["Valor Perdido (CLP)"]);
    r.precio=num(r.precio||r["Precio Unit. (CLP)"]||r["Precio Unitario"]||r["Precio neto"]);
    if(!r.valor && r.precio && r.cantKG) r.valor=r.precio*r.cantKG;
    let dTotal=diffDays(r.fechaCreacionLote,r.fechaVenc);
    let dIng=diffDays(r.fechaIngreso,r.fechaVenc);
    r.vidaTotalDias=dTotal; r.vidaIngresoDias=dIng;
    r.vidaTotalMeses=months(dTotal); r.vidaIngresoMeses=months(dIng);
    r.consumidaAntesPct=(dTotal&&dIng!=null&&dTotal>0)?Math.max(0,Math.min(100,(1-(dIng/dTotal))*100)):null;
    r.mesVenc=ym(r.fechaVenc); r.mesKey=r.mesVenc;
    r.diasAVencer=diffDays(new Date(),r.fechaVenc);
    return r;
  }
  function lossRows(){let a=[];try{if(window.S&&Array.isArray(S.loss))a=S.loss}catch(e){};a.forEach(enrich);return a}
  function stockRows(){let a=[];try{if(window.S&&Array.isArray(S.stock))a=S.stock}catch(e){};a.forEach(enrich);return a}
  function group(arr,key){
    let m={}; arr.forEach(r=>{let k=key(r)||"—"; if(!m[k])m[k]={key:k,valor:0,kg:0,lotes:0,items:[]}; m[k].valor+=num(r.valor);m[k].kg+=num(r.cantKG);m[k].lotes++;m[k].items.push(r)});
    return Object.values(m);
  }
  function avg(arr,prop){let v=arr.map(r=>r[prop]).filter(x=>x!=null&&isFinite(x)); return v.length?v.reduce((a,b)=>a+b,0)/v.length:null}
  function chipByDays(d){
    if(d==null)return '<span class="mv15-chip mv15-blue">Sin dato</span>';
    if(d<30)return '<span class="mv15-chip mv15-red">&lt;30 días</span>';
    if(d<60)return '<span class="mv15-chip mv15-orange">30-60 días</span>';
    if(d<90)return '<span class="mv15-chip mv15-yellow">60-90 días</span>';
    return '<span class="mv15-chip mv15-green">&gt;90 días</span>';
  }
  function miniBars(data,label,value,fmt,maxRows){
    data=data.slice(0,maxRows||10); let mx=Math.max(1,...data.map(value));
    return '<div class="mv15-bars">'+data.map(d=>{let v=value(d),p=Math.max(2,Math.round(v/mx*100)); return '<div class="mv15-row"><div class="mv15-name" title="'+label(d)+'">'+label(d)+'</div><div class="mv15-track"><div class="mv15-fill" style="width:'+p+'%"></div></div><div class="mv15-val">'+fmt(v)+'</div></div>'}).join('')+'</div>';
  }
  function comboChart(data){
    if(!data.length)return '<div class="mv15-note">Sin datos.</div>';
    data=data.slice(-12);
    let W=900,H=320,pL=58,pR=46,pT=34,pB=44;
    let maxVal=Math.max(1,...data.map(d=>d.valor)), maxKg=Math.max(1,...data.map(d=>d.kg));
    let innerW=W-pL-pR, innerH=H-pT-pB, gap=10, bw=Math.max(16,(innerW/data.length)-gap);
    function x(i){return pL+i*(innerW/data.length)+gap/2}
    function yVal(v){return pT+innerH-(v/maxVal)*innerH}
    function yKg(v){return pT+innerH-(v/maxKg)*innerH}
    let pts=data.map((d,i)=>[x(i)+bw/2,yVal(d.valor),d]);
    let path=pts.map((pt,i)=>(i?'L':'M')+pt[0].toFixed(1)+' '+pt[1].toFixed(1)).join(' ');
    let bars=data.map((d,i)=>{let h=(d.kg/maxKg)*innerH; return '<rect x="'+x(i).toFixed(1)+'" y="'+(pT+innerH-h).toFixed(1)+'" width="'+bw.toFixed(1)+'" height="'+h.toFixed(1)+'" rx="8" fill="#00b140" opacity=".72"><title>'+d.key+' · '+fmtKg(d.kg)+' · '+fmtMoney(d.valor)+'</title></rect>'}).join('');
    let labels=data.map((d,i)=>'<text x="'+(x(i)+bw/2).toFixed(1)+'" y="'+(H-14)+'" text-anchor="middle" font-size="11" fill="#475569">'+d.key.slice(5)+'</text>').join('');
    let circles=pts.map(pt=>'<circle cx="'+pt[0]+'" cy="'+pt[1]+'" r="6" fill="#004529"><title>'+pt[2].key+' · '+fmtMoney(pt[2].valor)+' · '+fmtKg(pt[2].kg)+'</title></circle>').join('');
    let grid=[0,.25,.5,.75,1].map(t=>'<line x1="'+pL+'" y1="'+(pT+innerH*(1-t))+'" x2="'+(W-pR)+'" y2="'+(pT+innerH*(1-t))+'" stroke="#e2e8f0"/>').join('');
    return '<div class="mv15-legend"><span><i class="mv15-dot kg"></i>KG perdidos</span><span><i class="mv15-dot val"></i>Valor perdido CLP</span></div><svg viewBox="0 0 '+W+' '+H+'" style="width:100%;height:auto">'+grid+'<line x1="'+pL+'" y1="'+(pT+innerH)+'" x2="'+(W-pR)+'" y2="'+(pT+innerH)+'" stroke="#cbd5e1"/><line x1="'+pL+'" y1="'+pT+'" x2="'+pL+'" y2="'+(pT+innerH)+'" stroke="#cbd5e1"/>'+bars+'<path d="'+path+'" fill="none" stroke="#004529" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>'+circles+labels+'<text x="'+pL+'" y="20" font-size="13" fill="#334155" font-weight="850">Últimos 12 meses por fecha de vencimiento</text><text x="'+(W-pR)+'" y="20" text-anchor="end" font-size="12" fill="#64748b">Barras: KG · Línea: CLP</text></svg>';
  }
  function filterRange(arr){
    let f=document.getElementById("mv15From")?.value, t=document.getElementById("mv15To")?.value;
    return arr.filter(r=>{let v=day(r.fechaVenc); if(!v)return false; if(f&&v<day(f))return false; if(t&&v>day(t))return false; return true});
  }
  function tableRows(arr){
    return arr.map(r=>'<tr><td>'+r.mat+'</td><td>'+r.desc+'</td><td>'+r.proveedor+'</td><td>'+r.lote+'</td><td>'+fmtDate(r.fechaCreacionLote)+'</td><td>'+fmtDate(r.fechaIngreso)+'</td><td>'+fmtDate(r.fechaVenc)+'</td><td><b>'+(r.diasDuracion||'—')+' días</b></td><td>'+fmtKg(r.cantKG)+'</td><td><b>'+fmtMoney(r.valor)+'</b></td></tr>').join('');
  }
  function renderExec(){
    let all=lossRows(); if(!all.length)return "";
    let now=new Date(), y=now.getFullYear(), m=now.getMonth();
    let ytd=all.filter(r=>r.fechaVenc&&r.fechaVenc.getFullYear()===y);
    let cur=all.filter(r=>r.fechaVenc&&r.fechaVenc.getFullYear()===y&&r.fechaVenc.getMonth()===m);
    let next30=stockRows().filter(r=>r.fechaVenc&&r.diasAVencer!=null&&r.diasAVencer>=0&&r.diasAVencer<=30);
    let riskVal=next30.reduce((s,r)=>s+(r.valor||r.precio*r.cantKG||0),0);
    let avgDur=avg(all,"diasDuracion");
    let byMonth=group(all,r=>r.mesVenc).sort((a,b)=>a.key.localeCompare(b.key));
    let byProd=group(all,r=>r.mat+" · "+r.desc).sort((a,b)=>b.valor-a.valor);
    let byProv=group(all,r=>r.proveedor).sort((a,b)=>b.valor-a.valor);
    let pareto=0, acc=0, total=byProd.reduce((s,x)=>s+x.valor,0); for(let x of byProd){acc+=x.valor;pareto++; if(total&&acc/total>=.8)break}
    return '<div class="mv15-shell" id="mv15Exec">'+
      '<div class="mv15-kpis">'+
        '<div class="mv15-kpi"><b>'+fmtMoney(ytd.reduce((s,r)=>s+r.valor,0))+'</b><span>Costo vencido YTD</span><small>Por fecha vencimiento '+y+'</small></div>'+
        '<div class="mv15-kpi"><b>'+fmtMoney(cur.reduce((s,r)=>s+r.valor,0))+'</b><span>Costo mes actual</span><small>'+ym(now)+'</small></div>'+
        '<div class="mv15-kpi"><b>'+fmtMoney(riskVal)+'</b><span>Riesgo próximos 30 días</span><small>'+next30.length+' lotes próximos a vencer</small></div>'+
        '<div class="mv15-kpi"><b>'+(avgDur==null?'—':Math.round(avgDur)+' días')+'</b><span>Días duración prom.</span><small>Desde stock SAP</small></div>'+
      '</div>'+
      '<div class="mv15-grid2">'+
        '<div class="mv15-card"><h3>📊 Tendencia ejecutiva</h3><p>Comparación mensual de valor perdido y KG vencidos. El mes se calcula con fecha de vencimiento, no con fecha de movimiento.</p>'+comboChart(byMonth)+'</div>'+
        '<div class="mv15-card"><h3>⚠️ Riesgo 30 días</h3>'+miniBars(group(next30,r=>r.mat+" · "+r.desc).sort((a,b)=>b.valor-a.valor),d=>d.key,d=>d.valor,fmtShort,8)+'<div class="mv15-note">Estimación usando stock actual, fecha de vencimiento y precio disponible.</div></div>'+
      '</div>'+
      '<div class="mv15-grid3">'+
        '<div class="mv15-card"><h3>🥇 Top productos</h3>'+miniBars(byProd,d=>d.key,d=>d.valor,fmtShort,10)+'<div class="mv15-note">Pareto: '+pareto+' productos explican aprox. 80% del valor perdido.</div></div>'+
        '<div class="mv15-card"><h3>🏭 Top proveedores</h3>'+miniBars(byProv,d=>d.key,d=>d.valor,fmtShort,10)+'</div>'+
        '<div class="mv15-card"><h3>📦 Días duración por proveedor</h3>'+miniBars(group(all,r=>r.proveedor).map(p=>{p.avg=avg(p.items,"diasDuracion");return p}).filter(p=>p.avg!=null).sort((a,b)=>b.avg-a.avg),d=>d.key,d=>d.avg,v=>Math.round(v)+" días",10)+'<div class="mv15-note">Campo tomado desde Días Duración del stock SAP. Fecha Recepción viene desde MB51 Fe.contabilización.</div></div>'+
      '</div>'+
    '</div>';
  }
  function renderRangePanel(){
    let all=lossRows(); if(!all.length)return "";
    let filtered=filterRange(all);
    let totalVal=filtered.reduce((s,r)=>s+r.valor,0), totalKg=filtered.reduce((s,r)=>s+r.cantKG,0);
    let avgR=avg(filtered,"diasDuracion");
    return '<div class="mv15-card" id="mv15RangePanel"><h3>🔎 Costos y productos vencidos por rango</h3><div class="mv15-filter"><div class="field"><label>Vencidos desde</label><input type="date" id="mv15From" value="'+(document.getElementById("mv15From")?.value||"")+'"></div><div class="field"><label>Vencidos hasta</label><input type="date" id="mv15To" value="'+(document.getElementById("mv15To")?.value||"")+'"></div><button class="mv15-btn green" id="mv15Apply" type="button">Aplicar</button><button class="mv15-btn gray" id="mv15Clear" type="button">Limpiar</button></div><div class="mv15-kpis"><div class="mv15-card"><b>'+fmtMoney(totalVal)+'</b><span>Costo vencido rango</span></div><div class="mv15-card"><b>'+fmtKg(totalKg)+'</b><span>Kg vencidos rango</span></div><div class="mv15-card"><b>'+(avgR==null?'—':Math.round(avgR)+' días')+'</b><span>Días duración prom.</span><small>Desde stock SAP</small></div></div><div class="mv15-table" style="margin-top:12px"><table><thead><tr><th>Material</th><th>Descripción</th><th>Proveedor</th><th>Lote</th><th>Fecha Fabricación</th><th>Fecha Recepción</th><th>Fecha Vencimiento</th><th>Días duración</th><th>KG</th><th>Valor</th></tr></thead><tbody>'+(filtered.length?tableRows(filtered):'<tr><td colspan="10">Sin vencidos en el rango seleccionado.</td></tr>')+'</tbody></table></div></div>';
  }
  function inject(){
    let sec=document.getElementById("sec-resumen")||document.querySelector(".section.active")||document.querySelector("main");
    if(sec){
      let old14=document.getElementById("mv14Exec"); if(old14) old14.remove();
      if(!document.getElementById("mv15Exec")){
        let div=document.createElement("div"); div.innerHTML=renderExec(); sec.insertBefore(div,sec.firstChild);
      }
    }
    let per=document.getElementById("sec-perdidas")||sec;
    if(per){
      let old=document.getElementById("mv14RangePanel"); if(old) old.remove();
      if(!document.getElementById("mv15RangePanel")){
        let div=document.createElement("div"); div.innerHTML=renderRangePanel(); per.appendChild(div); setTimeout(bind,0);
      }
    }
    cleanLastPriceColumns();
  }
  function bind(){
    let a=document.getElementById("mv15Apply"), c=document.getElementById("mv15Clear");
    if(a&&!a.__b){a.__b=true;a.onclick=rerenderRange}
    if(c&&!c.__b){c.__b=true;c.onclick=()=>{let f=document.getElementById("mv15From"),t=document.getElementById("mv15To"); if(f)f.value=""; if(t)t.value=""; rerenderRange()}}
  }
  function rerenderRange(){let old=document.getElementById("mv15RangePanel"); if(old){old.outerHTML=renderRangePanel(); bind(); cleanLastPriceColumns();}}
  function cleanLastPriceColumns(){
    document.querySelectorAll("table").forEach(tbl=>{
      if(tbl.__mv15Cleaned)return;
      let ths=[...tbl.querySelectorAll("thead th")];
      let idxs=ths.map((th,i)=>({txt:th.textContent.toLowerCase(),i})).filter(x=>x.txt.includes("último precio")||x.txt.includes("ultimo precio")||x.txt.trim()==="precio"||x.txt.includes("fecha últ")||x.txt.includes("fecha ult")||x.txt.includes("vida útil")||x.txt.includes("vida util")||x.txt.includes("% consumida")).map(x=>x.i).sort((a,b)=>b-a);
      if(!idxs.length)return;
      tbl.__mv15Cleaned=true;
      tbl.querySelectorAll("tr").forEach(tr=>{
        idxs.forEach(i=>{if(tr.children[i])tr.children[i].remove()})
      });
    });
  }
  let old=window.renderAll;
  if(typeof old==="function"&&!old.__mv15){
    window.renderAll=function(){let r=old.apply(this,arguments);setTimeout(inject,0);return r}; window.renderAll.__mv15=true;
  }
  if(document.readyState==="loading")document.addEventListener("DOMContentLoaded",()=>setTimeout(inject,700)); else setTimeout(inject,700);
  setTimeout(inject,1800);
})();

;

(function(){
  const KEY='mv32DashboardScale';
  const allowed=['80','90','100','110','120'];
  function applyScale(v){
    v=String(v||localStorage.getItem(KEY)||'100');
    if(!allowed.includes(v)) v='100';
    allowed.forEach(x=>document.body.classList.remove('mv32-scale-'+x));
    document.body.classList.add('mv32-scale-'+v);
    try{localStorage.setItem(KEY,v)}catch(e){}
    document.querySelectorAll('.mv32-size-btn').forEach(b=>b.classList.toggle('active',b.dataset.scale===v));
  }
  function panelHTML(){
    const current=String(localStorage.getItem(KEY)||'100');
    const opts=[['80','Compacta 80%'],['90','Compacta 90%'],['100','Normal 100%'],['110','Grande 110%'],['120','Presentación 120%']];
    return `<div class="mv32-size-panel" id="mv32SizePanel">
      <div class="mv32-size-title">🎛️ Tamaño visual <small>Regula el tamaño del dashboard y la tabla de lotes</small></div>
      <div class="mv32-size-buttons">${opts.map(o=>`<button type="button" class="mv32-size-btn ${current===o[0]?'active':''}" data-scale="${o[0]}">${o[1]}</button>`).join('')}</div>
    </div>`;
  }
  function injectPanel(){
    const wrap=document.querySelector('.wrap');
    if(!wrap) return;
    if(!document.getElementById('mv32SizePanel')){
      const box=document.createElement('div');
      box.innerHTML=panelHTML();
      wrap.insertBefore(box.firstElementChild, wrap.firstElementChild);
    }
    document.querySelectorAll('.mv32-size-btn').forEach(btn=>{
      if(btn.__mv32) return; btn.__mv32=true;
      btn.addEventListener('click',()=>applyScale(btn.dataset.scale));
    });
    applyScale(localStorage.getItem(KEY)||'100');
  }
  const oldRender=window.renderAll;
  if(typeof oldRender==='function' && !oldRender.__mv32){
    window.renderAll=function(){const r=oldRender.apply(this,arguments); setTimeout(injectPanel,0); return r};
    window.renderAll.__mv32=true;
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>setTimeout(injectPanel,300)); else setTimeout(injectPanel,300);
  setTimeout(injectPanel,1200);
})();

;

(function(){
  const KEY='mv33ViewConfig';
  const defaults={view:'compact',comment:'medium',density:'compact',hidden:false};
  function load(){try{return Object.assign({},defaults,JSON.parse(localStorage.getItem(KEY)||'{}'))}catch(e){return Object.assign({},defaults)}}
  function save(c){try{localStorage.setItem(KEY,JSON.stringify(c))}catch(e){}}
  function apply(c){document.body.classList.add('mv33-on');['compact','normal','large','presentation'].forEach(x=>document.body.classList.remove('mv33-view-'+x));['small','medium','large'].forEach(x=>document.body.classList.remove('mv33-comment-'+x));['compact','normal','wide'].forEach(x=>document.body.classList.remove('mv33-density-'+x));document.body.classList.add('mv33-view-'+c.view,'mv33-comment-'+c.comment,'mv33-density-'+c.density);const p=document.getElementById('mv33ViewPanel');if(p)p.classList.toggle('mv33-hidden',!!c.hidden)}
  function panel(c){return `<div class="mv33-view-panel ${c.hidden?'mv33-hidden':''}" id="mv33ViewPanel"><div class="mv33-view-head"><div><b>🎛️ Ajustar vista</b><br><span>Tabla y comentarios</span></div><button class="mv33-view-min" id="mv33Toggle" title="Minimizar/mostrar">${c.hidden?'⚙':'−'}</button></div><div class="mv33-view-body"><div class="mv33-view-row"><label>Vista</label><select id="mv33View"><option value="compact">Compacta</option><option value="normal">Normal</option><option value="large">Grande</option><option value="presentation">Presentación</option></select></div><div class="mv33-view-row"><label>Comentario</label><select id="mv33Comment"><option value="small">Pequeño</option><option value="medium">Medio</option><option value="large">Grande</option></select></div><div class="mv33-view-row"><label>Fila</label><select id="mv33Density"><option value="compact">Compacta</option><option value="normal">Normal</option><option value="wide">Alta</option></select></div><div class="mv33-view-actions"><button class="mv33-pill green" id="mv33Apply">Aplicar vista</button><button class="mv33-pill gray" id="mv33Reset">Reset</button></div></div></div>`}
  function inject(){let c=load();if(!document.getElementById('mv33ViewPanel'))document.body.insertAdjacentHTML('beforeend',panel(c));const v=document.getElementById('mv33View'),cm=document.getElementById('mv33Comment'),d=document.getElementById('mv33Density');if(v){v.value=c.view;cm.value=c.comment;d.value=c.density;}document.getElementById('mv33Apply')?.addEventListener('click',()=>{let n={view:v.value,comment:cm.value,density:d.value,hidden:false};save(n);apply(n)});document.getElementById('mv33Reset')?.addEventListener('click',()=>{let n=Object.assign({},defaults);save(n);document.getElementById('mv33ViewPanel')?.remove();inject();apply(n)});document.getElementById('mv33Toggle')?.addEventListener('click',()=>{let n=load();n.hidden=!n.hidden;save(n);document.getElementById('mv33ViewPanel')?.remove();inject();apply(n)});[v,cm,d].forEach(el=>el&&el.addEventListener('change',()=>{let n={view:v.value,comment:cm.value,density:d.value,hidden:false};save(n);apply(n)}));apply(c)}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(inject,300));else setTimeout(inject,300);setTimeout(inject,1200);
})();

;

import { initializeApp } from "https://www.gstatic.com/firebasejs/11.9.1/firebase-app.js";
import {
  getFirestore,
  collection,
  getDocs,
  doc,
  setDoc,
  deleteDoc,
  serverTimestamp
} from "https://www.gstatic.com/firebasejs/11.9.1/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyCxifqfJD89epa8MVLjDesydh5pLiIoNTU",
  authDomain: "dashboard-calidad-y-costos.firebaseapp.com",
  projectId: "dashboard-calidad-y-costos",
  storageBucket: "dashboard-calidad-y-costos.firebasestorage.app",
  messagingSenderId: "256388106071",
  appId: "1:256388106071:web:f8e6a05da4926d5015e012",
  measurementId: "G-8KVX39G2LG"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const COMMENTS_COLLECTION = "comentarios";
const LOCAL_KEY = "mvDetalleComentariosGestionV1";

let firebaseComments = {};
let firebaseReady = false;
let firebaseError = null;

function safeDocId(key){
  try{
    return btoa(unescape(encodeURIComponent(String(key || ""))))
      .replace(/\+/g, "-")
      .replace(/\//g, "_")
      .replace(/=+$/g, "");
  }catch(e){
    return String(key || "").replace(/[^\w.-]/g, "_").slice(0, 120);
  }
}

function readLocalComments(){
  try { return JSON.parse(localStorage.getItem(LOCAL_KEY) || "{}"); }
  catch(e){ return {}; }
}

function writeLocalComments(map){
  try { localStorage.setItem(LOCAL_KEY, JSON.stringify(map || {})); }
  catch(e){}
}

async function loadFirebaseComments(){
  try{
    const snap = await getDocs(collection(db, COMMENTS_COLLECTION));
    const remote = {};
    snap.forEach(d => {
      const data = d.data() || {};
      const key = data.key || d.id;
      if (data.comentario && String(data.comentario).trim()) {
        remote[key] = String(data.comentario).trim();
      }
    });
    firebaseComments = Object.assign({}, readLocalComments(), remote);
    writeLocalComments(firebaseComments);
    firebaseReady = true;
    firebaseError = null;
    updateFirebaseStatus();
    if (typeof window.renderAll === "function") {
      setTimeout(() => window.renderAll(), 150);
    }
  }catch(err){
    firebaseError = err;
    firebaseReady = false;
    updateFirebaseStatus();
    console.error("Error cargando comentarios desde Firestore:", err);
  }
}

async function saveFirebaseComment(key, value){
  const clean = String(value || "").trim();
  const local = readLocalComments();

  if(clean) {
    local[key] = clean;
    firebaseComments[key] = clean;
  } else {
    delete local[key];
    delete firebaseComments[key];
  }
  writeLocalComments(local);

  try{
    const ref = doc(db, COMMENTS_COLLECTION, safeDocId(key));
    if(clean){
      await setDoc(ref, {
        key,
        comentario: clean,
        actualizadoEn: serverTimestamp(),
        origen: "dashboard-calidad-costos",
        version: "v36-auto-github-firestore"
      }, { merge: true });
    } else {
      await deleteDoc(ref);
    }
    firebaseReady = true;
    firebaseError = null;
    updateFirebaseStatus("✅ Comentario guardado en Firebase");
    return true;
  }catch(err){
    firebaseError = err;
    updateFirebaseStatus("⚠️ Guardado local; no se pudo sincronizar con Firebase");
    console.error("Error guardando comentario en Firestore:", err);
    return false;
  }
}

function updateFirebaseStatus(msg){
  let status = document.getElementById("firebaseCommentStatus");
  if(!status){
    const tools = document.querySelector(".detail-comment-tools");
    if(tools){
      const div = document.createElement("div");
      div.id = "firebaseCommentStatus";
      div.className = "detail-comment-help";
      div.style.maxWidth = "420px";
      div.innerHTML = "☁️ Comentarios Firebase: conectando...";
      tools.appendChild(div);
      status = div;
    }
  }
  if(status){
    if(msg) status.textContent = msg;
    else if(firebaseReady) status.textContent = "☁️ Comentarios compartidos activos: Firebase conectado.";
    else if(firebaseError) status.textContent = "⚠️ Firebase sin conexión. Se guardará localmente.";
    else status.textContent = "☁️ Comentarios Firebase: conectando...";
  }
}

// Reemplaza funciones originales del dashboard.
window.loadComments = function(){
  return Object.assign({}, readLocalComments(), firebaseComments);
};

window.saveComments = function(map){
  firebaseComments = Object.assign({}, map || {});
  writeLocalComments(firebaseComments);
};

window.getGestionComment = function(r){
  try { return window.loadComments()[window.commentKey(r)] || ""; }
  catch(e){ return ""; }
};

window.setGestionComment = function(key, value){
  saveFirebaseComment(key, value);
};

// Segundo listener: mejora el estado visual del botón tras sincronizar.
document.addEventListener("click", async (e) => {
  if(e.target && e.target.classList && e.target.classList.contains("comment-apply")){
    const td = e.target.closest("td");
    const ta = td ? td.querySelector(".comment-box") : null;
    const st = td ? td.querySelector(".comment-saved") : null;
    if(!ta) return;

    if(st){
      st.textContent = "☁️ Sincronizando...";
      st.classList.remove("warn");
      st.classList.add("ok");
    }

    const ok = await saveFirebaseComment(e.target.dataset.commentKey, ta.value);

    if(st){
      if(ok){
        st.textContent = ta.value.trim() ? "☁️ Guardado Firebase" : "Comentario eliminado";
      }else{
        st.textContent = ta.value.trim() ? "💾 Guardado local" : "Eliminado local";
      }
      st.classList.remove("warn");
      st.classList.add("ok");
    }
  }
}, true);

// Inserta un pequeño indicador cuando se renderice el detalle.
const oldRenderAll = window.renderAll;
if(typeof oldRenderAll === "function" && !oldRenderAll.__firebaseWrapped){
  window.renderAll = function(){
    const r = oldRenderAll.apply(this, arguments);
    setTimeout(() => updateFirebaseStatus(), 200);
    return r;
  };
  window.renderAll.__firebaseWrapped = true;
}

window.firebaseDashboard = {
  db,
  loadFirebaseComments,
  saveFirebaseComment,
  get ready(){ return firebaseReady; },
  get error(){ return firebaseError; }
};

loadFirebaseComments();
setTimeout(updateFirebaseStatus, 1000);

