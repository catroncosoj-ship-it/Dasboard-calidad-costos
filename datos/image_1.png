        pass = pass.trim();

        if(AUTH_EMAILS.indexOf(email) >= 0 && pass === AUTH_PASSWORD){
          if(err) err.style.display = 'none';
          setAuthOk();
        }else{
          if(err) err.style.display = 'block';
        }
        return false;
      };
    }

    var logoutBtn = document.getElementById('logoutBtnFixed');
    if(logoutBtn){
      logoutBtn.onclick = function(ev){
        ev.preventDefault();
        logout();
        return false;
      };
    }
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initMVLogin);
  }else{
    initMVLogin();
  }
  setTimeout(initMVLogin, 300);
})();

