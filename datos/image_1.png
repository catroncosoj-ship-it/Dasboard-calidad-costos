var barsHTML = (typeof barsHTML !== 'undefined') ? barsHTML : '';

const $=id=>document.getElementById(id);
const SECTIONS=[['resumen','📊 Resumen'],['perdidas','💸 Pérdidas por mes'],['detalle','📋 Detalle lotes'],['stock','⏳ Stock/Vencimientos'],['motivos','🧩 Motivos'],['proveedores','🏭 Proveedores'],['productos','📦 Productos'],['q','✅ Calidad/Q'],['evaluacion','🧪 Evaluación materiales']];
const MOTIVOS_BASE=['Vencido','Decomiso','Siniestrado','Por Vencer','Reproceso','Diferencia de invent','Defectuoso','Devolucion a proveed'];
const COLOR={'Vencido':'#c4372d','Decomiso':'#7c3aed','Siniestrado':'#df5a00','Por Vencer':'#b7950b','Reproceso':'#0e6655','Diferencia de invent':'#566573','Defectuoso':'#be123c','Devolucion a proveed':'#2563eb','Sin motivo':'#64748b','Vigente':'#00843d','Crítico 0-10':'#c4372d','Apelación cong. 10-14':'#df5a00','Política cong. 15-25':'#b7950b','Apelación ref. 25-30':'#2563eb','Crítico política 30-40':'#9333ea','Buen estado 40+':'#00843d'};
const S={active:'resumen',stock:[],loss:[],filters:{},priceMap:{},ingresoMap:{}};
const COMMENT_STORE_KEY='mvDetalleComentariosGestionV1';
function loadComments(){try{return JSON.parse(localStorage.getItem(COMMENT_STORE_KEY)||'{}')}catch(e){return {}}}
function saveComments(map){try{localStorage.setItem(COMMENT_STORE_KEY,JSON.stringify(map||{}))}catch(e){}}
function commentKey(r){return [r.mat,r.lote,r.motivo,fd(r.fechaCad)].map(x=>String(x||'').trim()).join('|')}
function getGestionComment(r){return loadComments()[commentKey(r)]||''}
function setGestionComment(k,v){let m=loadComments(); if(v&&String(v).trim()) m[k]=String(v).trim(); else delete m[k]; saveComments(m)}
function esc(v){return String(v??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
function norm(v){return String(v??'').trim()}
function lower(v){return norm(v).toLowerCase()}
function num(v){if(v==null||v==='')return 0;if(typeof v==='number')return isNaN(v)?0:v;let s=String(v).replace(/\./g,'').replace(',','.').replace(/[^0-9.-]/g,'');let n=parseFloat(s);return isNaN(n)?0:n}
function parseDate(v){
  if(!v)return null;
  if(v instanceof Date&&!isNaN(v))return v;
  if(typeof v==='number')return new Date(Math.round((v-25569)*86400000));
  let s=String(v).trim();
  if(!s)return null;
  let m=s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})/);
  if(m){let y=+m[3];if(y<100)y+=2000;let d=new Date(y,+m[2]-1,+m[1]);return isNaN(d)?null:d}
  let d=new Date(s);return isNaN(d)?null:d
}
function diffDays(a,b){a=parseDate(a);b=parseDate(b);if(!a||!b)return null;return Math.round((new Date(b.getFullYear(),b.getMonth(),b.getDate())-new Date(a.getFullYear(),a.getMonth(),a.getDate()))/86400000)}
function diffMonths(a,b){let d=diffDays(a,b);return d==null?null:+(d/30.4375).toFixed(1)}
function fmtLife(d){return d==null||!isFinite(d)?'—':(d<0?'⚠ Revisar lote':`${fmtNum(d,0)} días (${fmtNum(d/30.4375,1)} meses)`)}

function ym(d){return d?`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`:'Sin fecha'}
function fd(d){return d?d.toLocaleDateString('es-CL'):''}
function fmtCLP(n){return '$ '+Math.round(num(n)).toLocaleString('es-CL')}
function fmtNum(n,d=1){return num(n).toLocaleString('es-CL',{minimumFractionDigits:d,maximumFractionDigits:d})}
function pct(n){return (num(n)*100).toFixed(1).replace('.',',')+'%'}
function sum(a,k='valor'){return a.reduce((s,r)=>s+num(r[k]),0)}
function uniq(a,k){return new Set(a.map(r=>r[k]).filter(x=>x!==''&&x!=null)).size}
function group(a,fn){return a.reduce((m,r)=>{let k=typeof fn==='function'?fn(r):r[fn];k=k||'—';(m[k]||(m[k]=[])).push(r);return m},{})}
function badge(t){let cls='b-dif';let s=String(t||'');if(s.includes('Vencido')||s.includes('Crítico 0'))cls='b-vencido';else if(s.includes('Decomiso'))cls='b-decomiso';else if(s.includes('Siniestrado'))cls='b-siniestrado';else if(s.includes('Por Vencer')||s.includes('Política'))cls='b-por';else if(s.includes('Reproceso'))cls='b-reproceso';else if(s.includes('Q'))cls='b-q';else if(s.includes('Buen')||s==='Vigente'||s==='Sin Q')cls='b-ok';return `<span class="badge ${cls}">${esc(s||'—')}</span>`}
function estadoDias(d){d=num(d);if(d<0)return 'Vencido SAP'; if(d<=10)return 'Crítico 0-10'; if(d<=14)return 'Apelación cong. 10-14'; if(d<=25)return 'Política cong. 15-25'; if(d<=30)return 'Apelación ref. 25-30'; if(d<=40)return 'Crítico política 30-40'; return 'Buen estado 40+'}
async function readWB(file){
  if(!file) throw new Error('Archivo no seleccionado.');
  if(typeof XLSX==='undefined') throw new Error('No se cargó la librería XLSX. Revisa conexión a internet o vuelve a abrir el archivo.');
  try{
    const data = await file.arrayBuffer();
    return XLSX.read(data,{type:'array',cellDates:true});
  }catch(err){
    throw new Error('No se pudo leer el archivo "'+file.name+'". Verifica que sea Excel .xlsx válido. Detalle: '+(err&&err.message?err.message:String(err||'')));
  }
}

/* === V35 CARGA AUTOMÁTICA DESDE GITHUB / VERCEL ===
   Estos archivos deben existir en el repo dentro de la carpeta /datos.
   Si cambias el nombre de algún Excel en GitHub, actualiza también estas rutas. */
const AUTO_DATA_FILES = {
  stock: 'datos/LISTO STOCK PLANILLA WEB 25-05.XLSX',
  precios: 'datos/Precios por proveedor 07-05.XLSX',
  mb51: 'datos/MB51 PARA PLANILLA WEB FECHA INGRESO 27.05.XLSX'
};

async function readWBFromUrl(url,label){
  if(typeof XLSX==='undefined') throw new Error('No se cargó la librería XLSX.');
  const safeUrl = encodeURI(url) + '?v=' + Date.now(); // evita caché al actualizar archivos en GitHub/Vercel
  const res = await fetch(safeUrl,{cache:'no-store'});
  if(!res.ok){
    throw new Error('No se pudo descargar '+label+' desde '+url+' (HTTP '+res.status+'). Revisa que el archivo exista en GitHub/Vercel con ese nombre exacto.');
  }
  const data = await res.arrayBuffer();
  return XLSX.read(data,{type:'array',cellDates:true});
}

async function autoLoadGithubFiles(){
  try{
    if(window.__autoGithubLoading) return;
    window.__autoGithubLoading = true;
    const st = $('status');
    if(st) st.textContent = 'Cargando base centralizada desde GitHub...';

    const swb = await readWBFromUrl(AUTO_DATA_FILES.stock,'Stock SAP / Calidad');
    const pwb = await readWBFromUrl(AUTO_DATA_FILES.precios,'Precios por proveedor');
    const iwb = await readWBFromUrl(AUTO_DATA_FILES.mb51,'MB51 Fecha ingreso');

    const stockData = aoa(swb), priceData = aoa(pwb), ingresoData = aoa(iwb);
    if(!stockData.length) throw new Error('El archivo Stock SAP de GitHub no tiene filas visibles.');
    if(!priceData.length) throw new Error('El archivo de precios de GitHub no tiene filas visibles.');
    if(!ingresoData.length) throw new Error('El archivo MB51 de GitHub no tiene filas visibles.');

    process(stockData,priceData,ingresoData);
    if(st) st.textContent = `Base GitHub cargada: ${S.stock.length} registros SAP · ${S.loss.length} con motivo · ${Object.keys(S.ingresoMap||{}).length} ingresos MB51.`;
    renderAll();
    if(typeof setActive === 'function') setActive('resumen');
  }catch(err){
    console.error('Error carga automática GitHub:', err);
    const st = $('status');
    if(st) st.textContent = 'No se pudo cargar base GitHub. Usa carga manual o revisa nombres en /datos.';
    alert('No se pudo cargar automáticamente desde GitHub/Vercel: ' + (err&&err.message?err.message:String(err||'')));
  }finally{
    window.__autoGithubLoading = false;
  }
}
function aoa(wb){let ws=wb.Sheets[wb.SheetNames[0]];return XLSX.utils.sheet_to_json(ws,{defval:''})}
function buildPriceMap(rows){let map={};for(const r of rows){let mat=norm(r['Material']).split('.')[0];let precio=num(r['Precio neto']);let fecha=parseDate(r['Fecha documento']);if(!mat||!precio)continue;if(!map[mat]||((fecha||0)>(map[mat].fecha||0)))map[mat]={precio,fecha}}return map}
function ingresoKey(mat,lote){return norm(mat).split('.')[0]+'|'+norm(lote).split('.')[0]}
function buildIngresoMap(rows){
  let map={};
  for(const r of rows){
    let mat=norm(r['Material']).split('.')[0];
    let lote=norm(r['Lote']).split('.')[0];
    let fecha=parseDate(r['Fe.contabilización'])||parseDate(r['Fe.contabilizacion'])||parseDate(r['Fecha contabilización'])||parseDate(r['Fecha contabilizacion']);
    if(!mat||!lote||!fecha)continue;
    let k=ingresoKey(mat,lote);
    // Si el lote aparece más de una vez en MB51, se usa la primera fecha contable como fecha real de ingreso.
    if(!map[k] || fecha < map[k]) map[k]=fecha;
  }
  return map;
}
function motivoFrom(text){let m=norm(text);if(!m)return '';let ml=lower(m);if(ml.includes('vencido'))return 'Vencido';if(ml.includes('decomiso'))return 'Decomiso';if(ml.includes('siniestr'))return 'Siniestrado';if(ml.includes('por vencer'))return 'Por Vencer';if(ml.includes('reproceso'))return 'Reproceso';if(ml.includes('diferencia'))return 'Diferencia de invent';if(ml.includes('defect'))return 'Defectuoso';if(ml.includes('devol'))return 'Devolucion a proveed';return m}
function process(stockRows, priceRows, ingresoRows=[]){
  S.priceMap=buildPriceMap(priceRows);
  S.ingresoMap=buildIngresoMap(ingresoRows);
  S.stock=[];
  S.loss=[];
  for(const r of stockRows){
    let mat=norm(r['Material']).split('.')[0];
    let lote=norm(r['Lote']).split('.')[0];
    let precio=(S.priceMap[mat]||{}).precio||0;
    let pfecha=(S.priceMap[mat]||{}).fecha||null;
    let stock=num(r['Stock total']);

    let fechaMov=parseDate(r['Fecha Movimiento']);
    let fechaCad=parseDate(r['FeCaduc/FePreferCons'])||parseDate(r['Fecha Vencimiento'])||parseDate(r['Fecha vencimiento'])||parseDate(r['Vencimiento']);

    // Fecha de recepción/ingreso: se toma SOLO desde MB51 columna Fe.contabilización.
    // No usar Fecha EM, Última entrada ni Fecha Movimiento en este campo.
    let fechaIngreso=S.ingresoMap[ingresoKey(mat,lote)]||null;

    // Fecha de fabricación real del lote desde SAP. No usar Fecha Creación Lote porque no siempre coincide con fabricación.
    let fechaCrea=parseDate(r['Fe.fabricación'])||parseDate(r['Fecha Fabricación'])||parseDate(r['Fecha fabricacion'])||parseDate(r['Fecha Fabricacion'])||null;

    // Días Duración viene directo desde SAP/planilla.
    let diasDuracion = num(r['Días Duración']||r['Dias Duración']||r['Días Duracion']||r['Dias Duracion']);

    let dias=num(r['Días Disponible']);
    let motivo=motivoFrom(r['Desc. Motivo del movimiento']);
    let q=norm(r['Diferenciación stock']).toUpperCase()==='Q';
    let comentario=norm(r['Desc. Motivo del movimiento'])||norm(r['Texto de clase de movimiento'])||'';

    // Campos de vida útil anulados para panel: no se muestran en KPI ni tabla.
    let vidaTotalDias=diffDays(fechaCrea,fechaCad);
    if((vidaTotalDias==null||!isFinite(vidaTotalDias)) && num(r['Días Duración'])>0) vidaTotalDias=num(r['Días Duración']);
    let vidaIngresoDiasRaw=diffDays(fechaIngreso,fechaCad);
    let ingresoPosteriorVencimiento=vidaIngresoDiasRaw!=null && vidaIngresoDiasRaw<0;
    let vidaIngresoDias=ingresoPosteriorVencimiento?null:vidaIngresoDiasRaw;
    let vidaTotalMeses=vidaTotalDias==null?null:+(vidaTotalDias/30.4375).toFixed(1);
    let vidaIngresoMeses=vidaIngresoDias==null?null:+(vidaIngresoDias/30.4375).toFixed(1);
    let pctConsumida=(vidaTotalDias&&vidaIngresoDias!=null)?Math.max(0,Math.min(1,1-(vidaIngresoDias/vidaTotalDias))):null;

    let base={
      mat,desc:norm(r['Descrip. Material'])||'—',proveedor:norm(r['Nombre Proveedor'])||'—',lote,
      fechaMov,mes:ym(fechaCad),fechaCad,fechaIngreso,fechaCrea,dias,stock,unidad:norm(r['Unidad medida base'])||'KG',
      precio,pfecha,valor:stock*precio,motivoCod:norm(r['Motivo movimiento']),mov:norm(r['Texto de clase de movimiento']),
      motivo,comentario,q,obsoleto:num(lote)<1000050000,
      vidaTotalDias,vidaIngresoDias,vidaTotalMeses,vidaIngresoMeses,pctConsumida,ingresoPosteriorVencimiento,diasDuracion
    };
    S.stock.push({...base,estado:estadoDias(dias)});
    if(motivo){S.loss.push(base)}
  }
}
function filtered(rows,scope){let f=S.filters[scope]||{};let out=rows;let q=lower(f.search);if(q)out=out.filter(r=>[r.mes,r.motivo,r.mat,r.desc,r.proveedor,r.lote,r.comentario,r.mov].some(x=>lower(x).includes(q)));if(f.mes&&f.mes!=='Todos')out=out.filter(r=>r.mes===f.mes);let df=f.dateFrom?parseDate(f.dateFrom):null,dt=f.dateTo?parseDate(f.dateTo):null;if(df)out=out.filter(r=>r.fechaCad&&r.fechaCad>=df);if(dt)out=out.filter(r=>r.fechaCad&&r.fechaCad<=dt);if(f.motivo&&f.motivo!=='Todos')out=out.filter(r=>r.motivo===f.motivo);if(f.estado&&f.estado!=='Todos')out=out.filter(r=>r.estado===f.estado);if(f.prov&&f.prov!=='Todos')out=out.filter(r=>r.proveedor===f.prov);if(f.mat&&f.mat!=='Todos')out=out.filter(r=>r.mat===f.mat);if(f.q&&f.q!=='Todos')out=out.filter(r=>f.q==='Q'?r.q:!r.q);let min=f.min!==''&&f.min!=null?num(f.min):null,max=f.max!==''&&f.max!=null?num(f.max):null;if(min!=null)out=out.filter(r=>num(r.dias)>=min);if(max!=null)out=out.filter(r=>num(r.dias)<=max);return out}
function options(arr,val){return [...new Set(arr.filter(Boolean))].sort((a,b)=>String(a).localeCompare(String(b))).map(x=>`<option ${x===val?'selected':''}>${esc(x)}</option>`).join('')}
function filters(scope,kind){let base=kind==='stock'?S.stock.filter(r=>!r.obsoleto&&num(r.dias)>=0):S.loss;let f=S.filters[scope]||{};return `<div class="filters"><div class="field"><label>Buscar</label><input data-s="${scope}" data-f="search" value="${esc(f.search||'')}" placeholder="Material, producto, lote, proveedor..."></div><div class="field"><label>Mes vencimiento</label><select data-s="${scope}" data-f="mes"><option>Todos</option>${options(base.map(r=>r.mes),f.mes)}</select></div>${kind==='stock'?`<div class="field"><label>Estado</label><select data-s="${scope}" data-f="estado"><option>Todos</option>${options(base.map(r=>r.estado),f.estado)}</select></div>`:`<div class="field"><label>Vencidos desde</label><input data-s="${scope}" data-f="dateFrom" type="date" value="${esc(f.dateFrom||'')}"></div><div class="field"><label>Vencidos hasta</label><input data-s="${scope}" data-f="dateTo" type="date" value="${esc(f.dateTo||'')}"></div><div class="field"><label>Motivo</label><select data-s="${scope}" data-f="motivo"><option>Todos</option>${options(base.map(r=>r.motivo),f.motivo)}</select></div>`}<div class="field"><label>Proveedor</label><select data-s="${scope}" data-f="prov"><option>Todos</option>${options(base.map(r=>r.proveedor),f.prov)}</select></div><div class="field"><label>Material</label><select data-s="${scope}" data-f="mat"><option>Todos</option>${options(base.map(r=>r.mat),f.mat)}</select></div><div class="field"><label>Días mín.</label><input data-s="${scope}" data-f="min" type="number" value="${esc(f.min||'')}"></div><div class="field"><label>Días máx.</label><input data-s="${scope}" data-f="max" type="number" value="${esc(f.max||'')}"></div></div>`}
function kpiHTML(rows,type='loss'){return `<div class="kpi-row"><div class="kpi red"><div class="v">${fmtCLP(sum(rows))}</div><div class="l">Valor total</div></div><div class="kpi orange"><div class="v">${fmtNum(sum(rows,'stock'))} KG</div><div class="l">Cantidad total</div></div><div class="kpi navy"><div class="v">${fmtNum(rows.length,0)} lotes<br>${fmtNum(uniq(rows,'mat'),0)} materiales</div><div class="l">Registros únicos</div></div></div>`}
function avgVal(rows,k){let vals=rows.map(r=>r[k]).filter(v=>v!=null&&isFinite(v));return vals.length?vals.reduce((a,b)=>a+b,0)/vals.length:null}
function kpiLifeHTML(rows){return ''}

function chartMonthly(rows){
  let by=Object.entries(group(rows,'mes')).map(([m,rs])=>({mes:m,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length})).sort((a,b)=>a.mes.localeCompare(b.mes));
  if(!by.length)return '<div class="empty">Sin datos</div>';
  let total=sum(rows), peak=by.reduce((a,b)=>b.valor>a.valor?b:a,by[0]);
  let last=[...by].reverse().find(x=>x.valor>0)||by[by.length-1];
  let improvement=(peak.valor>0 && last.valor<=peak.valor)?Math.round((1-last.valor/peak.valor)*100):0;
  let lastIdx=by.findIndex(x=>x.mes===last.mes), prev= lastIdx>0?by[lastIdx-1]:null;
  let mom=prev&&prev.valor>0?Math.round((last.valor/prev.valor-1)*100):null;
  let data=by.length>14?by.slice(-14):by;
  let W=920,H=360,pL=64,pR=62,pT=44,pB=58,innerW=W-pL-pR,innerH=H-pT-pB;
  let maxVal=Math.max(1,...data.map(d=>d.valor));
  let maxKg=Math.max(1,...data.map(d=>d.kg));
  let step=innerW/data.length, bw=Math.max(18,Math.min(46,step*.56));
  let x=i=>pL+i*step+step/2;
  let yVal=v=>pT+innerH-(v/maxVal)*innerH;
  let yKg=v=>pT+innerH-(v/maxKg)*innerH;
  let grid=[0,.25,.5,.75,1].map(t=>`<line x1="${pL}" y1="${pT+innerH*(1-t)}" x2="${W-pR}" y2="${pT+innerH*(1-t)}" stroke="#e2e8f0"/>`).join('');
  let bars=data.map((d,i)=>{
    let h=(d.valor/maxVal)*innerH, xx=x(i)-bw/2, yy=pT+innerH-h;
    let isPeak=d.mes===peak.mes, isLast=d.mes===last.mes;
    let fill=isPeak?'#dc2626':(isLast?'#00843d':'#16a34a');
    return `<rect x="${xx.toFixed(1)}" y="${yy.toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.max(3,h).toFixed(1)}" rx="8" fill="${fill}" opacity="${isPeak||isLast?'.95':'.62'}"><title>${esc(d.mes)} · ${fmtCLP(d.valor)} · ${fmtNum(d.kg)} KG</title></rect>` +
           `<text x="${x(i).toFixed(1)}" y="${Math.max(18,yy-8).toFixed(1)}" text-anchor="middle" font-size="10" fill="#0f5132" font-weight="900">${d.valor?('$'+Math.round(d.valor/1000000).toLocaleString('es-CL')+'M'):'$0'}</text>`;
  }).join('');
  let pts=data.map((d,i)=>[x(i),yKg(d.kg),d]);
  let path=pts.map((pt,i)=>(i?'L':'M')+pt[0].toFixed(1)+' '+pt[1].toFixed(1)).join(' ');
  let circles=pts.map(pt=>`<circle cx="${pt[0].toFixed(1)}" cy="${pt[1].toFixed(1)}" r="5" fill="#fff" stroke="#2563eb" stroke-width="3"><title>${esc(pt[2].mes)} · ${fmtNum(pt[2].kg)} KG</title></circle>`).join('');
  let labels=data.map((d,i)=>`<text x="${x(i).toFixed(1)}" y="${H-26}" text-anchor="middle" font-size="11" fill="#334155" font-weight="800">${esc(d.mes.slice(5))}</text><text x="${x(i).toFixed(1)}" y="${H-12}" text-anchor="middle" font-size="10" fill="#64748b">${esc(d.mes.slice(0,4))}</text>`).join('');
  let status = improvement>0 ? `MEJORA SOSTENIDA: -${improvement}% desde el pico ${esc(peak.mes)} hasta ${esc(last.mes)}` : `TENDENCIA EN REVISIÓN: último mes igual o superior al pico visible`;
  let momTxt = mom==null?'Sin comparación mes anterior':(mom<=0?`Último mes baja ${Math.abs(mom)}% vs mes anterior`:`Último mes sube ${mom}% vs mes anterior`);
  return `<div class="trend-card"><div class="trend-head"><div><b>📈 ${status}</b><span>${momTxt}. Click en un mes para abrir el detalle filtrado.</span></div><div class="trend-pill">Pico: ${fmtCLP(peak.valor)}<br>Último: ${fmtCLP(last.valor)}</div></div><div class="mv15-legend"><span><i class="mv15-dot val"></i>Valor perdido ($)</span><span><i class="mv15-dot kg"></i>Cantidad (KG)</span><span><i class="mv15-dot" style="background:#dc2626"></i>Pico máximo</span></div><svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;display:block">${grid}<line x1="${pL}" y1="${pT+innerH}" x2="${W-pR}" y2="${pT+innerH}" stroke="#cbd5e1"/><line x1="${pL}" y1="${pT}" x2="${pL}" y2="${pT+innerH}" stroke="#cbd5e1"/>${bars}<path d="${path}" fill="none" stroke="#2563eb" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>${circles}${labels}<text x="${pL}" y="24" font-size="13" fill="#00843d" font-weight="950">Valor perdido CLP</text><text x="${W-pR}" y="24" text-anchor="end" font-size="13" fill="#2563eb" font-weight="950">Cantidad KG</text></svg><div class="trend-foot">✅ La lectura ejecutiva se centra en la reducción desde el mes peak y en el último mes disponible.</div></div>`
}
function chartMotivos(rows){
  let entries=Object.entries(group(rows,'motivo')).map(([k,rs])=>({motivo:k,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length})).sort((a,b)=>b.valor-a.valor);
  if(!entries.length)return '<div class="empty">Sin datos</div>';
  let max=Math.max(...entries.map(e=>e.valor),1), total=entries.reduce((s,e)=>s+e.valor,0);
  return `<div class="motivo-card"><div class="trend-head"><div><b>✅ Pérdida por motivo priorizada</b><span>Ordenado de mayor a menor impacto para enfocar acciones correctivas.</span></div><div class="trend-pill">Principal: ${esc(entries[0].motivo)}<br>${pct(total?entries[0].valor/total:0)} del total</div></div><div class="motivo-bars">${entries.map((e,i)=>`<div class="motivo-row"><div class="motivo-name">${badge(e.motivo)}</div><div class="motivo-track"><div class="motivo-fill" style="width:${Math.max(2,e.valor/max*100)}%;background:${COLOR[e.motivo]||'#64748b'}"></div></div><div class="motivo-val"><b>${fmtCLP(e.valor)}</b><small>${fmtNum(e.kg)} KG · ${pct(total?e.valor/total:0)}</small></div></div>`).join('')}</div><div class="trend-foot">✅ Usar este panel para atacar primero los motivos con mayor valor perdido.</div></div>`
}

function sortControls(scope){
  let f=S.filters[scope]||{};
  return `<div class="sort-panel"><div class="field"><label>Ordenar por</label><select data-s="${scope}" data-f="sortBy"><option value="valor" ${(!f.sortBy||f.sortBy==='valor')?'selected':''}>Valor perdido</option><option value="kg" ${f.sortBy==='kg'?'selected':''}>Cantidad KG</option><option value="lotes" ${f.sortBy==='lotes'?'selected':''}>N° lotes</option><option value="mats" ${f.sortBy==='mats'?'selected':''}>Materiales únicos</option><option value="grupo" ${f.sortBy==='grupo'?'selected':''}>Nombre / Grupo</option></select></div><div class="field"><label>Dirección</label><select data-s="${scope}" data-f="sortDir"><option value="desc" ${(!f.sortDir||f.sortDir==='desc')?'selected':''}>Mayor a menor</option><option value="asc" ${f.sortDir==='asc'?'selected':''}>Menor a mayor</option></select></div></div>`
}
function applySort(entries,scope){
  let f=S.filters[scope]||{}, by=f.sortBy||'valor', dir=f.sortDir||'desc';
  entries.sort((a,b)=>{
    let av=by==='grupo'?String(a.k||''):num(a[by]);
    let bv=by==='grupo'?String(b.k||''):num(b[by]);
    if(by==='grupo') return dir==='asc'?av.localeCompare(bv):bv.localeCompare(av);
    return dir==='asc'?av-bv:bv-av;
  });
  return entries;
}
function chartTopGroups(rows,keyFn,limit=10,scope='proveedores'){
  let all=Object.entries(group(rows,keyFn)).map(([k,rs])=>({k,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length,mats:uniq(rs,'mat')}));
  let entries=applySort(all,scope).slice(0,limit);
  if(!entries.length)return '<div class="empty">Sin datos</div>';
  let maxVal=Math.max(...entries.map(e=>e.valor),1), maxKg=Math.max(...entries.map(e=>e.kg),1);
  let total=sum(rows);
  return `<div class="provider-legend"><span><i class="provider-dot"></i>Valor perdido</span><span><i class="provider-dot kg"></i>Cantidad KG</span><span>Top ${entries.length} según orden seleccionado</span></div><div class="provider-chart">${entries.map((e,i)=>`<div class="provider-row"><div class="provider-rank">${i+1}</div><div class="provider-name" title="${esc(e.k)}">${esc(e.k)}</div><div class="provider-bars"><div class="provider-track" title="Valor: ${fmtCLP(e.valor)}"><div class="provider-fill-value" style="width:${Math.max(2,e.valor/maxVal*100)}%"></div></div><div class="provider-track" title="KG: ${fmtNum(e.kg)}"><div class="provider-fill-kg" style="width:${Math.max(2,e.kg/maxKg*100)}%"></div></div></div><div class="provider-metrics"><b>${fmtCLP(e.valor)}</b>${fmtNum(e.kg)} KG · ${fmtNum(e.lotes,0)} lotes<br>${pct(total?e.valor/total:0)} del total</div></div>`).join('')}</div>`
}
function executiveAlerts(loss, stockValid){
  const venc=loss.filter(r=>r.motivo==='Vencido');
  const riesgo=stockValid.filter(r=>r.dias<=30);
  const sinPrecio=loss.filter(r=>!r.precio);
  const sinComent=loss.filter(r=>!String(getGestionComment(r)||'').trim()).length;
  const clsV=sum(venc)>500000?'danger':'warn';
  const clsR=riesgo.length?'warn':'info';
  return `<div class="v37-alert-grid">
    <div class="v37-alert ${clsV}"><b>${fmtCLP(sum(venc))}</b><span>Vencidos valorizados</span><small>${fmtNum(venc.length,0)} lotes · ${fmtNum(sum(venc,'stock'))} KG.</small></div>
    <div class="v37-alert ${clsR}"><b>${fmtNum(riesgo.length,0)}</b><span>Lotes riesgo ≤30 días</span><small>Vista rápida para priorizar consumo o revisión.</small></div>
    <div class="v37-alert info"><b>${fmtNum(sinPrecio.length,0)}</b><span>Registros sin precio</span><small>Revisar cruce con OC para valorizar correctamente.</small></div>
    <div class="v37-alert ${sinComent?'warn':'info'}"><b>${fmtNum(sinComent,0)}</b><span>Sin comentario gestión</span><small>Útil para cerrar explicación de vencimientos.</small></div>
  </div>`;
}
function renderResumen(){let loss=S.loss, stockValid=S.stock.filter(r=>!r.obsoleto&&num(r.dias)>=0);let venc=loss.filter(r=>r.motivo==='Vencido');return `<section class="section active" id="sec-resumen">${executiveAlerts(loss,stockValid)}${kpiHTML(loss)}${kpiLifeHTML(loss)}<div class="grid2"><div class="card"><div class="section-title">Pérdida por mes de vencimiento</div><div class="card-pad">${chartMonthly(loss)}</div></div><div class="card"><div class="section-title">Pérdida por motivo</div><div class="card-pad">${chartMotivos(loss)}</div></div></div><div class="grid3"><div class="card"><div class="section-title">Vencidos</div><div class="card-pad"><b>${fmtCLP(sum(venc))}</b><br><span class="small">${fmtNum(venc.length,0)} lotes · ${fmtNum(sum(venc,'stock'))} KG</span></div></div><div class="card"><div class="section-title">Stock riesgo ≤30 días</div><div class="card-pad"><b>${fmtCLP(sum(stockValid.filter(r=>r.dias<=30)))}</b><br><span class="small">Solo apartado Stock/Vencimientos aplica restricción de lote.</span></div></div><div class="card"><div class="section-title">Sin precio</div><div class="card-pad"><b>${fmtNum(loss.filter(r=>!r.precio).length,0)}</b><br><span class="small">Registros con motivo sin cruce de precio.</span></div></div></div></section>`}
function renderPerdidas(){let rows=filtered(S.loss,'perdidas');let meses=Object.entries(group(rows,'mes')).sort((a,b)=>a[0].localeCompare(b[0]));let total=sum(rows);return `<section class="section" id="sec-perdidas">${filters('perdidas','loss')}${kpiHTML(rows)}${kpiLifeHTML(rows)}<div class="card"><div class="section-title">Pérdida por mes de vencimiento real</div><div class="table-wrap"><table><thead><tr><th>Mes de Vencimiento<br>(FeCaduc/FePreferCons)</th><th>N° Lotes</th><th>Materiales<br>Únicos</th><th>Cantidad<br>(KG)</th><th>Valor Perdido<br>(CLP)</th><th>% del Total</th></tr></thead><tbody>${meses.map(([m,rs])=>`<tr><td>${esc(m)}</td><td class="c">${fmtNum(rs.length,0)}</td><td class="c">${fmtNum(uniq(rs,'mat'),0)}</td><td class="r">${fmtNum(sum(rs,'stock'))}</td><td class="r">${fmtCLP(sum(rs))}</td><td class="c">${pct(total?sum(rs)/total:0)}</td></tr>`).join('')}<tr class="total-foot"><td>TOTAL GENERAL</td><td class="c">${fmtNum(rows.length,0)}</td><td class="c">${fmtNum(uniq(rows,'mat'),0)}</td><td class="r">${fmtNum(sum(rows,'stock'))}</td><td class="r">${fmtCLP(total)}</td><td class="c">100,0%</td></tr></tbody></table></div></div><div class="card"><div class="section-title">Gráfico mensual legible</div><div class="card-pad">${chartMonthly(rows)}</div></div></section>`}
function renderDetalle(){let allRows=filtered(S.loss,'detalle').sort((a,b)=>b.valor-a.valor);let f=S.filters.detalle||{};let rows=allRows.filter(r=>{let c=getGestionComment(r).trim(); if(f.comentarioGestion==='Con comentario')return !!c; if(f.comentarioGestion==='Sin comentario')return !c; return true});return `<section class="section" id="sec-detalle">${filters('detalle','loss')}${kpiHTML(rows)}<div class="card"><div class="section-title">Detalle completo de lotes con motivo (${rows.length} registros)</div><div class="detail-comment-tools"><div class="field"><label>Comentarios gestión</label><select data-s="detalle" data-f="comentarioGestion"><option ${(!f.comentarioGestion||f.comentarioGestion==='Todos')?'selected':''}>Todos</option><option ${f.comentarioGestion==='Con comentario'?'selected':''}>Con comentario</option><option ${f.comentarioGestion==='Sin comentario'?'selected':''}>Sin comentario</option></select></div><div class="detail-comment-help">Escribe directo en la tabla. Edita el comentario y presiona Aplicar para guardarlo. Luego puedes modificarlo y volver a aplicar.</div></div><div class="table-wrap"><table><thead><tr><th>Mes<br>Vencimiento</th><th>Motivo</th><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Lote</th><th>Fecha<br>Fabricación</th><th>Fecha<br>Recepción</th><th>Fecha<br>Vencimiento</th><th>Días<br>Duración</th><th>Cantidad<br>(KG)</th><th>Unidad</th><th>Valor<br>Perdido (CLP)</th><th class="comment-col">Comentario<br>gestión</th></tr></thead><tbody><tr class="total-row"><td>TOTAL</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td class="r">${fmtNum(sum(rows,'stock'))}</td><td></td><td class="r">${fmtCLP(sum(rows))}</td><td></td></tr>${rows.map((r,i)=>{let k=commentKey(r);let c=getGestionComment(r);let sample= i===0 && !c ? 'Ej: Fecha SAP incorrecta respecto a ficha técnica. Reclamo enviado a proveedor / Calidad.' : '';return `<tr><td>${esc(r.mes)}</td><td>${badge(r.motivo)}</td><td class="c">${esc(r.mat)}</td><td class="desc">${esc(r.desc)}</td><td class="prov">${esc(r.proveedor)}</td><td class="c">${esc(r.lote)}</td><td class="c">${fd(r.fechaCrea)}</td><td class="c">${fd(r.fechaIngreso)}</td><td class="c">${fd(r.fechaCad)}</td><td class="c"><b>${r.diasDuracion?fmtNum(r.diasDuracion,0)+' días':'—'}</b></td><td class="r">${fmtNum(r.stock)}</td><td class="c">${esc(r.unidad)}</td><td class="r" style="background:#fff2cc"><b>${fmtCLP(r.valor)}</b></td><td class="comment-cell"><div class="comment-card"><div class="comment-top"><span class="comment-title">📝 Comentario gestión</span><span class="comment-chip">Editable</span></div><textarea class="comment-box" data-comment-key="${esc(k)}" placeholder="${esc(sample||'Agregar motivo, acción o responsable...')}">${esc(c)}</textarea><div class="comment-actions"><button type="button" class="comment-apply" data-comment-key="${esc(k)}">✓ Aplicar comentario</button><span class="comment-saved ${c?'ok':''}">${c?'💾 Guardado':'Pendiente'}</span></div></div></td></tr>`}).join('')}</tbody></table></div></div></section>`}
function renderStock(){let base=S.stock.filter(r=>!r.obsoleto&&num(r.dias)>=0);let rows=filtered(base,'stock').sort((a,b)=>a.dias-b.dias);return `<section class="section" id="sec-stock">${filters('stock','stock')}<div class="kpi-row"><div class="kpi green"><div class="v">${fmtNum(rows.length,0)}</div><div class="l">Registros visibles</div></div><div class="kpi orange"><div class="v">${fmtNum(sum(rows,'stock'))} KG</div><div class="l">Stock total</div></div><div class="kpi navy"><div class="v">${fmtCLP(sum(rows))}</div><div class="l">Valor inventario</div></div></div><div class="card"><div class="section-title">Stock y vencimientos - Restricción aplicada solo aquí</div><div class="table-wrap"><table><thead><tr><th>Estado</th><th>Q</th><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Lote</th><th>Creación<br>Lote</th><th>Fecha<br>Vencimiento</th><th>Días<br>Disponibles</th><th>Stock<br>Total</th><th>Precio</th><th>Valor</th><th>Comentario</th></tr></thead><tbody>${rows.map(r=>`<tr><td>${badge(r.estado)}</td><td>${r.q?badge('Q'):badge('Sin Q')}</td><td class="c">${esc(r.mat)}</td><td class="desc">${esc(r.desc)}</td><td class="prov">${esc(r.proveedor)}</td><td class="c">${esc(r.lote)}</td><td class="c">${fd(r.fechaCrea)}</td><td class="c">${fd(r.fechaCad)}</td><td class="r">${fmtNum(r.dias,0)}</td><td class="r">${fmtNum(r.stock)}</td><td class="r">${fmtCLP(r.precio)}</td><td class="r">${fmtCLP(r.valor)}</td><td>${esc(r.comentario||'—')}</td></tr>`).join('')}</tbody></table></div></div></section>`}
function renderGroup(scope,title,keyFn){let rows=filtered(S.loss,scope);let entries=Object.entries(group(rows,keyFn)).map(([k,rs])=>({k,rs,valor:sum(rs),kg:sum(rs,'stock'),lotes:rs.length,mats:uniq(rs,'mat')}));entries=applySort(entries,scope);let chart = scope==='proveedores'?`<div class="card"><div class="section-title">Top 10 proveedores - comparativo valor y KG</div><div class="card-pad">${sortControls(scope)}${chartTopGroups(rows,keyFn,10,scope)}</div></div>`:`<div class="card card-pad">${sortControls(scope)}</div>`;return `<section class="section" id="sec-${scope}">${filters(scope,'loss')}${chart}<div class="card"><div class="section-title">${esc(title)}</div><div class="table-wrap"><table><thead><tr><th>Grupo</th><th>N° Lotes</th><th>Materiales<br>Únicos</th><th>Cantidad<br>(KG)</th><th>Valor Perdido<br>(CLP)</th><th>% del Total</th><th>Motivo principal</th></tr></thead><tbody>${entries.map(e=>{let main=Object.entries(group(e.rs,'motivo')).map(([m,rs])=>[m,sum(rs)]).sort((a,b)=>b[1]-a[1])[0]||['—',0];let total=sum(rows);return `<tr><td class="desc"><b>${esc(e.k)}</b></td><td class="c">${fmtNum(e.lotes,0)}</td><td class="c">${fmtNum(e.mats,0)}</td><td class="r">${fmtNum(e.kg)}</td><td class="r">${fmtCLP(e.valor)}</td><td class="c">${pct(total?e.valor/total:0)}</td><td>${badge(main[0])}</td></tr>`}).join('')}</tbody></table></div></div></section>`}
function renderMotivos(){let rows=filtered(S.loss,'motivos');return `<section class="section" id="sec-motivos">${filters('motivos','loss')}<div class="grid2"><div class="card"><div class="section-title">Gráfico por motivo</div><div class="card-pad">${chartMotivos(rows)}</div></div><div class="card"><div class="section-title">Tabla por motivo</div><div class="table-wrap"><table><thead><tr><th>Motivo</th><th>Lotes</th><th>Materiales</th><th>KG</th><th>Valor</th></tr></thead><tbody>${Object.entries(group(rows,'motivo')).map(([m,rs])=>`<tr><td>${badge(m)}</td><td class="c">${fmtNum(rs.length,0)}</td><td class="c">${fmtNum(uniq(rs,'mat'),0)}</td><td class="r">${fmtNum(sum(rs,'stock'))}</td><td class="r">${fmtCLP(sum(rs))}</td></tr>`).join('')}</tbody></table></div></div></div></section>`}
function renderQ(){let rows=filtered(S.stock.filter(r=>r.q),'q');return `<section class="section" id="sec-q">${filters('q','stock')}<div class="card"><div class="section-title">Calidad / Q con y sin comentario</div><div class="table-wrap"><table><thead><tr><th>Q</th><th>Material</th><th class="desc">Descripción</th><th>Lote</th><th class="prov">Proveedor</th><th>Creación</th><th>Vencimiento</th><th>Días</th><th>Stock</th><th>Comentario/Motivo</th></tr></thead><tbody>${rows.map(r=>`<tr><td>${badge(r.comentario?'Q con comentario':'Q sin comentario')}</td><td class="c">${esc(r.mat)}</td><td class="desc">${esc(r.desc)}</td><td class="c">${esc(r.lote)}</td><td class="prov">${esc(r.proveedor)}</td><td class="c">${fd(r.fechaCrea)}</td><td class="c">${fd(r.fechaCad)}</td><td class="r">${fmtNum(r.dias,0)}</td><td class="r">${fmtNum(r.stock)}</td><td>${esc(r.comentario||'—')}</td></tr>`).join('')}</tbody></table></div></div></section>`}


function evalQuarter(){let d=new Date(),q=Math.floor(d.getMonth()/3)+1;return d.getFullYear()+'-T'+q}
function evalKey(item){return [item.mat,item.proveedor].map(x=>String(x||'').trim()).join('|')}
function evalCategory(desc){let t=lower(desc);if(t.includes('queso')||t.includes('mozz')||t.includes('cheddar')||t.includes('emmental'))return 'Lácteos';if(t.includes('jamon')||t.includes('chorizo')||t.includes('pepperoni')||t.includes('carne'))return 'Cárnicos';if(t.includes('harina')||t.includes('semolina')||t.includes('mejorador')||t.includes('levadura'))return 'Secos / masas';if(t.includes('film')||t.includes('estuche')||t.includes('bolsa')||t.includes('caja'))return 'Material empaque';if(t.includes('salsa')||t.includes('pulpa')||t.includes('tomate'))return 'Salsas / vegetales';return 'Otros'}
function loadSkuEvals(){try{return JSON.parse(localStorage.getItem('mvEvaluacionMaterialesV1')||'{}')}catch(e){return {}}}
function saveSkuEvals(map){try{localStorage.setItem('mvEvaluacionMaterialesV1',JSON.stringify(map||{}))}catch(e){}}
function getSkuEval(item){let m=(window.loadMaterialEvals?window.loadMaterialEvals():loadSkuEvals());return m[evalKey(item)]||{}}
function evalStatus(avg){avg=Number(avg)||0;if(avg>=4)return 'Aprobado';if(avg>=3)return 'Observado';return avg>0?'Crítico':'Pendiente'}
function evalStatusClass(st){return st==='Aprobado'?'ok':(st==='Observado'||st==='Pendiente'?'obs':'crit')}
function buildSkuMaster(){let map={};[...(S.stock||[]),...(S.loss||[])].forEach(r=>{if(!r||!r.mat)return;let k=[r.mat,r.proveedor||'—'].join('|');if(!map[k])map[k]={mat:r.mat,desc:r.desc||'—',proveedor:r.proveedor||'—',categoria:evalCategory(r.desc||''),lotes:0,kg:0,valor:0,loss:0};map[k].lotes+=1;map[k].kg+=num(r.stock);map[k].valor+=num(r.valor);if((S.loss||[]).includes(r))map[k].loss+=num(r.valor)});return Object.values(map).sort((a,b)=>a.mat.localeCompare(b.mat)||a.proveedor.localeCompare(b.proveedor))}
function renderEvaluacion(){
  let all=buildSkuMaster();let evals=(window.loadMaterialEvals?window.loadMaterialEvals():loadSkuEvals());let f=S.filters.evaluacion||{};
  let rows=all.map(item=>{let ev=evals[evalKey(item)]||{};let scores=['funcional','calidad','tecnico'].map(k=>Number(ev[k])||0).filter(x=>x>0);let avg=scores.length?scores.reduce((a,b)=>a+b,0)/scores.length:0;let st=ev.estado||evalStatus(avg);return {...item,ev,avg,estado:st,ft:ev.ft||'',fechaRev:ev.fechaRev||'',trimestre:ev.trimestre||evalQuarter(),comentario:ev.comentario||''}});
  let q=lower(f.search);if(q)rows=rows.filter(r=>[r.mat,r.desc,r.proveedor,r.categoria,r.ft,r.estado,r.comentario].some(x=>lower(x).includes(q)));
  if(f.prov&&f.prov!=='Todos')rows=rows.filter(r=>r.proveedor===f.prov);if(f.cat&&f.cat!=='Todos')rows=rows.filter(r=>r.categoria===f.cat);if(f.estado&&f.estado!=='Todos')rows=rows.filter(r=>r.estado===f.estado);if(f.ft&&f.ft!=='Todos')rows=rows.filter(r=>f.ft==='Con FT'?!!r.ft:!r.ft);
  let completos=rows.filter(r=>r.ft&&r.avg>0).length, crit=rows.filter(r=>r.estado==='Crítico').length, sinft=rows.filter(r=>!r.ft).length;
  return `<section class="section" id="sec-evaluacion"><div class="eval-intro"><div class="eval-info"><b>🧪 Evaluación trimestral de materiales y proveedores</b><span>Listado maestro de SKU utilizados, proveedor y código FT. Permite evaluar cada 3 meses desempeño funcional, calidad/inocuidad y cumplimiento técnico/especificaciones. La información queda guardada en este navegador y, si Firebase está disponible, se sincroniza para todos.</span></div><div class="eval-kpis"><div class="eval-kpi"><b>${fmtNum(rows.length,0)}</b><span>SKU / proveedor visibles</span></div><div class="eval-kpi warn"><b>${fmtNum(sinft,0)}</b><span>Sin código FT</span></div><div class="eval-kpi danger"><b>${fmtNum(crit,0)}</b><span>Críticos</span></div></div></div><div class="card"><div class="section-title">Maestro SKU + evaluación técnica trimestral</div><div class="eval-filters"><div class="field"><label>Buscar</label><input data-s="evaluacion" data-f="search" value="${esc(f.search||'')}" placeholder="SKU, proveedor, FT, comentario..."></div><div class="field"><label>Proveedor</label><select data-s="evaluacion" data-f="prov"><option>Todos</option>${options(all.map(r=>r.proveedor),f.prov)}</select></div><div class="field"><label>Categoría</label><select data-s="evaluacion" data-f="cat"><option>Todos</option>${options(all.map(r=>r.categoria),f.cat)}</select></div><div class="field"><label>Estado</label><select data-s="evaluacion" data-f="estado"><option>Todos</option>${options(['Aprobado','Observado','Crítico','Pendiente'],f.estado)}</select></div><div class="field"><label>FT</label><select data-s="evaluacion" data-f="ft"><option>Todos</option><option ${f.ft==='Con FT'?'selected':''}>Con FT</option><option ${f.ft==='Sin FT'?'selected':''}>Sin FT</option></select></div></div><div class="table-wrap"><table class="eval-table"><thead><tr><th>Material</th><th class="desc">Descripción</th><th class="prov">Proveedor</th><th>Categoría</th><th>Código FT</th><th>Trimestre</th><th>Funcional<br>proceso/producto</th><th>Calidad e<br>inocuidad</th><th>Cumplimiento<br>técnico</th><th>Promedio</th><th>Estado</th><th>Última<br>revisión</th><th>Comentario / acción</th><th>Guardar</th></tr></thead><tbody>${rows.map(r=>{let k=evalKey(r),ev=r.ev||{};return `<tr data-eval-row="${esc(k)}"><td class="c"><b>${esc(r.mat)}</b></td><td class="desc">${esc(r.desc)}</td><td class="prov">${esc(r.proveedor)}</td><td>${esc(r.categoria)}</td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="ft" value="${esc(r.ft)}" placeholder="FT-000"></td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="trimestre" value="${esc(r.trimestre)}"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="funcional" type="number" min="1" max="5" value="${esc(ev.funcional||'')}" placeholder="1-5"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="calidad" type="number" min="1" max="5" value="${esc(ev.calidad||'')}" placeholder="1-5"></td><td class="c"><input class="eval-score eval-input" data-eval-k="${esc(k)}" data-field="tecnico" type="number" min="1" max="5" value="${esc(ev.tecnico||'')}" placeholder="1-5"></td><td class="c"><b>${r.avg?fmtNum(r.avg,1):'—'}</b></td><td class="c"><span class="eval-status ${evalStatusClass(r.estado)}">${esc(r.estado)}</span></td><td><input class="eval-ft eval-input" data-eval-k="${esc(k)}" data-field="fechaRev" type="date" value="${esc(r.fechaRev)}"></td><td><input class="eval-comment eval-input" data-eval-k="${esc(k)}" data-field="comentario" value="${esc(r.comentario)}" placeholder="Reclamos, defectos, mejora, responsable..."></td><td class="c"><button class="eval-save" data-eval-k="${esc(k)}">Guardar</button><span class="eval-saved" data-eval-status="${esc(k)}">${r.ft||r.avg?'Guardado':'Pendiente'}</span></td></tr>`}).join('')}</tbody></table></div><div class="eval-export"><small>${fmtNum(completos,0)} evaluaciones completas de ${fmtNum(rows.length,0)} visibles · Escala 1 bajo / 5 excelente.</small><button class="eval-btn-gray" id="evalExportBtn">Exportar evaluación CSV</button></div></div></section>`
}

function renderSection(id){
  if(id==='resumen') return renderResumen();
  if(id==='perdidas') return renderPerdidas();
  if(id==='detalle') return renderDetalle();
  if(id==='stock') return renderStock();
  if(id==='motivos') return renderMotivos();
  if(id==='proveedores') return renderGroup('proveedores','Pérdidas por proveedor',r=>r.proveedor);
  if(id==='productos') return renderGroup('productos','Pérdidas por producto',r=>`${r.mat} · ${r.desc}`);
  if(id==='q') return renderQ();
  if(id==='evaluacion') return renderEvaluacion();
  return renderResumen();
}

function renderAll(){
  if(!S.stock.length&&!S.loss.length){
    $('sectionsHost').innerHTML='<div class="card card-pad"><b>Carga los 3 archivos y presiona Aplicar.</b></div>';
    document.querySelectorAll('#nav button').forEach(b=>b.classList.toggle('active',b.dataset.id===S.active));
    return;
  }
  let active=S.active||'resumen';

  // Clave de rendimiento: renderiza SOLO el apartado visible, no todos los apartados.
  $('sectionsHost').innerHTML=renderSection(active);

  document.querySelectorAll('.section').forEach(x=>x.classList.add('active'));
  document.querySelectorAll('#nav button').forEach(b=>b.classList.toggle('active',b.dataset.id===active));
  bindFilters();
}

function setActive(id){
  S.active=id;
  renderAll();
}


function bindFilters(){
  let searchTimers = {};
  document.querySelectorAll('[data-s]').forEach(el=>{
    if(el.__boundFast) return;
    el.__boundFast = true;

    const handler = ()=>{
      const sc = el.dataset.s;
      const f = el.dataset.f;
      S.filters[sc] = S.filters[sc] || {};
      S.filters[sc][f] = el.value;

      if(f === 'search'){
        clearTimeout(searchTimers[sc]);
        searchTimers[sc] = setTimeout(()=>renderAll(), 280);
      }else{
        renderAll();
      }
    };

    if(el.dataset.f === 'search'){
      el.addEventListener('input', handler);
    }else{
      el.addEventListener('change', handler);
    }
  });
}


async function applyFiles(){
  try{
    let sf=$('stockFile').files[0],pf=$('priceFile').files[0],ifile=$('ingresoFile').files[0];
    if(!sf||!pf||!ifile){alert('Debes cargar los 3 archivos: Stock SAP, Precios proveedor y MB51 Fecha ingreso.');return}
    $('status').textContent='Procesando archivos...';
    let swb=await readWB(sf),pwb=await readWB(pf),iwb=await readWB(ifile);
    let stockData=aoa(swb), priceData=aoa(pwb), ingresoData=aoa(iwb);
    if(!stockData.length) throw new Error('El archivo Stock SAP no tiene filas visibles.');
    if(!priceData.length) throw new Error('El archivo de precios no tiene filas visibles.');
    if(!ingresoData.length) throw new Error('El archivo MB51 no tiene filas visibles.');
    process(stockData,priceData,ingresoData);
    $('status').textContent=`Cargado: ${S.stock.length} registros SAP · ${S.loss.length} con motivo · ${Object.keys(S.ingresoMap||{}).length} fechas MB51`;
    renderAll();
  }catch(e){
    console.error(e);
    const msg=(e&&e.message)?e.message:String(e||'Error desconocido');
    alert('Error procesando archivos: '+msg);
    $('status').textContent='Error al procesar';
  }
}
function exportCSV(){let rows=filtered(S.loss,'detalle');let f=S.filters.detalle||{};rows=rows.filter(r=>{let c=getGestionComment(r).trim(); if(f.comentarioGestion==='Con comentario')return !!c; if(f.comentarioGestion==='Sin comentario')return !c; return true});let headers=['Mes Vencimiento','Motivo','Material','Descripcion','Proveedor','Lote','Fecha Fabricacion','Fecha Recepcion','Fecha Vencimiento','Dias Duracion','Cantidad KG','Unidad','Precio Unit CLP','Fecha Ult Precio','Valor Perdido CLP','Comentario Gestion'];let csv=[headers.join(';')].concat(rows.map(r=>[r.mes,r.motivo,r.mat,r.desc,r.proveedor,r.lote,fd(r.fechaCrea),fd(r.fechaIngreso),fd(r.fechaCad),r.diasDuracion,r.stock,r.unidad,r.precio,fd(r.pfecha),Math.round(r.valor),getGestionComment(r)].map(x=>'"'+String(x??'').replaceAll('"','""')+'"').join(';'))).join('\n');let a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8'}));a.download='detalle_perdidas_sap_comentarios.csv';a.click()}

const AUTH_USERS=['ctroncoso@minutoverde.cl','abarrera@minutoverde.cl','rgubelin@minutoverde.cl','gconcha@minutoverde.cl'];
const AUTH_PASSWORD='programacion2026';
function initLogin(){
  if(localStorage.getItem('mvAuthOk')==='1')document.body.classList.add('auth-ok');
  let form=$('loginForm');
  if(form){form.onsubmit=e=>{e.preventDefault();let email=lower($('loginEmail').value);let pass=norm($('loginPassword').value);if(AUTH_USERS.includes(email)&&pass===AUTH_PASSWORD){localStorage.setItem('mvAuthOk','1');document.body.classList.add('auth-ok');$('loginError').style.display='none'}else{$('loginError').style.display='block'}}}
  let out=$('logoutBtn');
  if(out){out.onclick=()=>{localStorage.removeItem('mvAuthOk');document.body.classList.remove('auth-ok')}}
}

document.addEventListener('input',e=>{
  if(e.target&&e.target.classList&&e.target.classList.contains('comment-box')){
    const td=e.target.closest('td');
    const st=td?td.querySelector('.comment-saved'):null;
    if(st){st.textContent='● Cambios pendientes';st.classList.remove('ok');st.classList.add('warn');}
  }
});
document.addEventListener('click',e=>{
  if(e.target&&e.target.classList&&e.target.classList.contains('comment-apply')){
    const td=e.target.closest('td');
    const ta=td?td.querySelector('.comment-box'):null;
    if(!ta)return;
    setGestionComment(e.target.dataset.commentKey,ta.value);
    const st=td.querySelector('.comment-saved');
    if(st){st.textContent=ta.value.trim()?'💾 Guardado':'Comentario eliminado';st.classList.remove('warn');st.classList.add('ok');}
  }
});
function init(){initLogin();document.getElementById('nav').innerHTML=SECTIONS.map(([id,t])=>`<button data-id="${id}">${t}</button>`).join('');document.querySelectorAll('#nav button').forEach(b=>b.onclick=()=>setActive(b.dataset.id));$('applyBtn').onclick=applyFiles;if($('autoLoadBtn'))$('autoLoadBtn').onclick=autoLoadGithubFiles;$('resetBtn').onclick=()=>{S.filters={};renderAll()};$('exportBtn').onclick=exportCSV;renderAll();setActive('resumen');setTimeout(()=>{ if(location.protocol!=='file:') autoLoadGithubFiles(); }, 700)}
init();

